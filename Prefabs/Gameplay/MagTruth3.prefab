  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0443\u0440\u0435\u0433\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D
    \u0432 \u0442\u043E\u0442 \u0436\u0435 \u0434\u0435\u043D\u044C \u043F\u0440\u0438
    \u0441\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0438 \u043F\u0440\u043E\u0444\u0441\u043E\u044E\u0437\u043D\u043E\u0433\u043E
    \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430. \u0412\u0441\u0435 \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u0438
    \u0432\u0435\u0440\u043D\u0443\u043B\u0438\u0441\u044C \u043D\u0430 \u0441\u0432\u043E\u0438
    \u043C\u0435\u0441\u0442\u0430. \u041F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442: \u043B\u044E\u0431\u044B\u0435
    \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u0440\u0435\u0448\u0430\u044E\u0442\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u0430\u043D\u0430\u043B\u044B, \u0430 \u043D\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0441\u0430\u043C\u043E\u0443\u043F\u0440\u0430\u0432\u0441\u0442\u0432\u043E."
  m_isRightToLeft: 0
