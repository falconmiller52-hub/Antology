  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0420\u0435\u0434\u0430\u043A\u0446\u0438\u044F \u0433\u0430\u0437\u0435\u0442\u044B
    \"\u041F\u0440\u0430\u0432\u0434\u0430\" \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0442\u0451\u043F\u043B\u044B\u0445
    \u043E\u0442\u0437\u044B\u0432\u043E\u0432 \u043E\u0442 \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u0439.
    \u0416\u0438\u0442\u0435\u043B\u0438 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F\u0442
    \u0437\u0430 \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0435
    \u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u0435 \u0441\u043E\u0431\u044B\u0442\u0438\u0439
    \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443 \u0432 \u0442\u0440\u0443\u0434\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F. \"\u0412\u0430\u0448\u0430 \u0433\u0430\u0437\u0435\u0442\u0430
    \u0434\u043B\u044F \u043D\u0430\u0441 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440!\" \u2014 \u043F\u0438\u0448\u0435\u0442
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u0430\u044F \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
    \u0410. \u0412. \u0422\u0438\u043C\u043E\u0444\u0435\u0435\u0432\u0430. \u041C\u044B
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u043C \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0434\u043B\u044F \u0432\u0430\u0441!"
