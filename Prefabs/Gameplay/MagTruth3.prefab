  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u2014 \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u0441\u043E\u0431\u0430\u043A\u0430
    \u2014 \u0434\u0440\u0443\u0433 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.
    \u041D\u0435 \u0437\u043D\u0430\u044E. \u041C\u043E\u044F \u0441\u043E\u0431\u0430\u043A\u0430
    \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B\u0430 \u043D\u0430 \u043C\u043E\u0439
    \u043F\u0430\u0451\u043A \u0438 \u0443\u0448\u043B\u0430 \u043A \u0441\u043E\u0441\u0435\u0434\u0443.\n\u2014
    \u041E\u043F\u0442\u0438\u043C\u0438\u0441\u0442 \u0433\u043E\u0432\u043E\u0440\u0438\u0442:
    \u0441\u0442\u0430\u043A\u0430\u043D \u043D\u0430\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
    \u043F\u043E\u043B\u043E\u043D. \u041F\u0435\u0441\u0441\u0438\u043C\u0438\u0441\u0442:
    \u043D\u0430\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443 \u043F\u0443\u0441\u0442.
    \u0420\u0435\u0430\u043B\u0438\u0441\u0442: \u0440\u0435\u0431\u044F\u0442\u0430,
    \u044D\u0442\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0441\u0442\u0430\u043A\u0430\u043D \u043D\u0430 \u0442\u0440\u043E\u0438\u0445,
    \u0445\u0432\u0430\u0442\u0438\u0442 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C."
