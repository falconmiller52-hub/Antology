--- !u!114 &1697659160571955935
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7304986097157379910}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435.
    \u042D\u0442\u043E \u041A\u0430\u0442\u0438\u043D\u0430 \u043C\u0430\u043C\u0430.
    \u0424\u0430\u043C\u0438\u043B\u0438\u044E \u0437\u043D\u0430\u0435\u0442\u0435
    \u2014 \u044F \u043F\u0438\u0441\u0430\u043B\u0430 \u0440\u0430\u043D\u044C\u0448\u0435.
    \u041F\u0438\u0448\u0443 \u0432\u0430\u043C \u0443\u0436\u0435 \u0447\u0435\u0442\u0432\u0451\u0440\u0442\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E. \u041F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0435
    \u0442\u0440\u0438 \u0432\u044B \u043D\u0435 \u0437\u0430\u0447\u0438\u0442\u0430\u043B\u0438.
    \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C, \u0432\u044B \u0438\u0445
    \u0434\u0430\u0436\u0435 \u043D\u0435 \u0447\u0438\u0442\u0430\u043B\u0438. \u041D\u043E
    \u044F \u0431\u0443\u0434\u0443 \u043F\u0438\u0441\u0430\u0442\u044C, \u043F\u043E\u043A\u0430
    \u043C\u043E\u0433\u0443 \u0434\u0435\u0440\u0436\u0430\u0442\u044C \u043A\u0430\u0440\u0430\u043D\u0434\u0430\u0448.\n\u041C\u043E\u044E
    \u0434\u043E\u0447\u044C \u0437\u0432\u0430\u043B\u0438 \u041A\u0430\u0442\u044F.
    \u0415\u0439 \u0431\u044B\u043B\u043E \u043E\u0434\u0438\u043D\u043D\u0430\u0434\u0446\u0430\u0442\u044C.
    \u0423 \u043D\u0435\u0451 \u0431\u044B\u043B\u0438 \u0441\u0432\u0435\u0442\u043B\u044B\u0435
    \u0432\u043E\u043B\u043E\u0441\u044B \u0438 \u0449\u0435\u0440\u0431\u0438\u043D\u043A\u0430
    \u043C\u0435\u0436\u0434\u0443 \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u043C\u0438
    \u0437\u0443\u0431\u0430\u043C\u0438. \u041E\u043D\u0430 \u0431\u043E\u044F\u043B\u0430\u0441\u044C
    \u0442\u0435\u043C\u043D\u043E\u0442\u044B, \u043D\u043E \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0430\u0441\u044C.
    \u041F\u0440\u044F\u0442\u0430\u043B\u0430 \u0444\u043E\u043D\u0430\u0440\u0438\u043A
    \u043F\u043E\u0434 \u043F\u043E\u0434\u0443\u0448\u043A\u0443.\n\u0412\u044B
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B\u0438 \u0432 \u044D\u0444\u0438\u0440\u0435
    \u043F\u0440\u043E \u0441\u0443\u0434 \u043D\u0430\u0434 \u044D\u0442\u0438\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C. \u0412\u044B \u043D\u0430\u0437\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \xAB\u041B\u0435\u0441\u043D\u0438\u0447\u0438\u0439\xBB.
    \u0412\u044B \u0441\u043A\u0430\u0437\u0430\u043B\u0438 \u2014 \u043F\u044F\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u044C
    \u0434\u0435\u0442\u0435\u0439. \u041F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0451\u043D
    \u043A \u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0439 \u043A\u0430\u0437\u043D\u0438.
    \u0418 \u0432\u0441\u0451. \u0418 \u043F\u0435\u0440\u0435\u0448\u043B\u0438
    \u043A \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439 \u043D\u043E\u0432\u043E\u0441\u0442\u0438.\n\u042F
    \u0445\u043E\u0447\u0443 \u0437\u043D\u0430\u0442\u044C. \u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E
    \u0437\u043D\u0430\u0442\u044C. \u0427\u0442\u043E \u043E\u043D \u0441 \u043D\u0438\u043C\u0438
    \u0434\u0435\u043B\u0430\u043B. \u0413\u0434\u0435 \u043E\u043D\u0438 \u0431\u044B\u043B\u0438
    \u0432\u0441\u0451 \u044D\u0442\u043E \u0432\u0440\u0435\u043C\u044F. \u0413\u0434\u0435
    \u043C\u043E\u044F \u041A\u0430\u0442\u044F \u0431\u044B\u043B\u0430, \u043F\u043E\u043A\u0430
    \u044F \u0441\u0445\u043E\u0434\u0438\u043B\u0430 \u0441 \u0443\u043C\u0430 \u0438
    \u0440\u0430\u0441\u043A\u043B\u0435\u0438\u0432\u0430\u043B\u0430 \u0431\u0443\u043C\u0430\u0436\u043A\u0438
    \u0441 \u0435\u0451 \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439
    \u043F\u043E \u0432\u0441\u0435\u043C\u0443 \u0433\u043E\u0440\u043E\u0434\u0443.
    \u0427\u0442\u043E \u043E\u043D\u0430 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430.
    \u0417\u0432\u0430\u043B\u0430 \u043B\u0438 \u043E\u043D\u0430 \u043C\u0435\u043D\u044F.
    \u0412\u0435\u0440\u043D\u0438\u0442\u0435 \u0435\u0435... "
  m_isRightToLeft: 0
