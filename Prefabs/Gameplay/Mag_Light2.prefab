  m_text: "\u041E\u0434\u043D\u0430\u043A\u043E \u0431\u044B\u0432\u0448\u0438\u0439
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440 \u0432\u043E\u0434\u043E\u043E\u0447\u0438\u0441\u0442\u043D\u043E\u0439
    \u0441\u0442\u0430\u043D\u0446\u0438\u0438 \u0420. \u041D. \u0414\u0451\u043C\u0438\u043D,
    \u0443\u0432\u043E\u043B\u0435\u043D\u043D\u044B\u0439 \u0432 \u043F\u0440\u043E\u0448\u043B\u043E\u043C
    \u043C\u0435\u0441\u044F\u0446\u0435, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0444\u0438\u043B\u044C\u0442\u0440\u0443\u044E\u0449\u0435\u0435
    \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u043D\u0435
    \u043C\u0435\u043D\u044F\u043B\u043E\u0441\u044C \u0441 \u043D\u0430\u0447\u0430\u043B\u0430
    \u0437\u0438\u043C\u044B. \"\u041E\u043D\u0438 \u044D\u043A\u043E\u043D\u043E\u043C\u044F\u0442
    \u043D\u0430 \u0440\u0435\u0430\u0433\u0435\u043D\u0442\u0430\u0445. \u041E\u043D\u0430
    \u043D\u0435 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u0430\", \u2014
    \u0437\u0430\u044F\u0432\u0438\u043B \u0414\u0451\u043C\u0438\u043D."
