--- !u!114 &3580135450877917786
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2068758235255885852}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041E\u0447\u0435\u043D\u044C \u043F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0441\u0438\u0433\u043D\u0430\u043B \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u043E\u0432
    \u0432\u044B\u0441\u0448\u0435\u0433\u043E \u0441\u0432\u0435\u0442\u0430 \u043F\u0435\u0440\u0435\u043B\u043E\u0432\u0438\u043B
    \u0440\u0430\u0434\u0438\u043E\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C
    \u0415. \u0412. \u0415\u0440\u0448\u043E\u0432. \u0412\u043E\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0431\u0440\u0430\u0442\u0438\u0442\u044C \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u0441\u0442\u043E\u0438\u0442 \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430 \u043D\u0430\u0432\u044B\u043A\u0438 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430 \u0442\u043E, \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u0440\u0430\u0448\u043D\u0430 \u0442\u0435\u043C\u0430 \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u043E\u0432
    \u044D\u043B\u0438\u0442 \u043D\u0430\u0448\u0435\u0433\u043E \u0433\u043E\u0440\u043E\u0434\u0430.\n\"\u041F\u043E
    \u043F\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F\u043C... \u043D\u0435 \u0431\u043E\u043B\u044C\u0448\u0435
    \u0433\u043E\u0434\u0430, \u043B\u0438\u0431\u043E \u0442\u043E\u0433\u043E \u043C\u0435\u043D\u044C\u0448\u0435.
    \u041F\u043B\u0430\u043D \u043F\u043E \"\u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u043A\u0435\"
    \u0432\u0441\u0442\u0443\u043F\u0430\u0435\u0442 \u0432 \u0441\u0438\u043B\u0443,
    \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0435... \u043F\u0435\u0440\u0435\u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432 \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0443\u0435\u0442
    \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u0448\u0430\u043D\u0441\u043E\u0432 \u043D\u0430 \u0432\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0435\"\n\u0421\u0442\u043E\u0438\u0442
    \u043D\u0430\u043F\u043E\u043C\u043D\u0438\u0442\u044C, \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    5 \u0430\u043F\u0440\u0435\u043B\u044F. \u0432 \u0434\u0435\u043D\u044C \u043A\u043E\u0433\u0434\u0430
    \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u0445\u0432\u0430\u0447\u0435\u043D
    \u0441\u0438\u0433\u043D\u0430\u043B, \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E\u0441\u044C
    \u0437\u0430\u043A\u0440\u044B\u0442\u043E\u0435 \u0441\u043E\u0432\u0435\u0449\u0430\u043D\u0438\u0435
    \u0412\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430,
    \u0433\u0434\u0435 \u0432\u044B\u043D\u043E\u0441\u0438\u043B\u0438\u0441\u044C
    \u0437\u043B\u043E\u0431\u043E\u0434\u043D\u0435\u0432\u043D\u044B\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u044B
    \u043E \u0432\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0438.\n\u041D\u043E
    \u043A\u0430\u043A\u0438\u043C\u0438 \u043C\u0435\u0442\u043E\u0434\u0430\u043C\u0438
    \u043E\u043D\u0438 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u044B \"\u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C
    \u0432\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0435\" - \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u043B\u0438\u0448\u044C \u0434\u043E\u0433\u0430\u0434\u044B\u0432\u0430\u0442\u044C\u0441\u044F"
