  m_text: "\u0416\u0438\u0442\u0435\u043B\u0438 \u0412\u043E\u0441\u0442\u043E\u0447\u043D\u043E\u0433\u043E
    \u0440\u0430\u0439\u043E\u043D\u0430 \u0441\u043E\u043E\u0431\u0449\u0430\u044E\u0442
    \u043E \u043C\u0443\u0442\u043D\u043E\u0439 \u0432\u043E\u0434\u0435 \u0441 \u0440\u0435\u0437\u043A\u0438\u043C
    \u0437\u0430\u043F\u0430\u0445\u043E\u043C \u0438\u0437 \u0432\u043E\u0434\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u0430.
    \u041D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0435\u043C\u0435\u0439
    \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0438\u0441\u044C \u0432 \u043C\u0435\u0434\u043F\u0443\u043D\u043A\u0442
    \u0441 \u0436\u0430\u043B\u043E\u0431\u0430\u043C\u0438 \u043D\u0430 \u0442\u043E\u0448\u043D\u043E\u0442\u0443
    \u0438 \u0433\u043E\u043B\u043E\u0432\u043D\u0443\u044E \u0431\u043E\u043B\u044C.
    \u041F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u044F \u043F\u043E \u0441\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u043E\u043C\u0443
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044E \u0437\u0430\u044F\u0432\u0438\u043B\u0430,
    \u0447\u0442\u043E \xAB\u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u0438
    \u043D\u0430\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u0432 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u0445
    \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u043C\u044B\u0445 \u043D\u043E\u0440\u043C. "
  m_isRightToLeft: 0
