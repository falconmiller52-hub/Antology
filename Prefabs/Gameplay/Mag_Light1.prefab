  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u0441\u0435 \u0431\u043E\u043B\u044C\u0448\u0435 \u0436\u0430\u043B\u043E\u0431
    \u043E\u0442 \u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u0437\u0430\u0442\u0440\u0430\u0433\u0438\u0432\u0430\u044E\u0442
    \u043C\u0430\u043B\u043E\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043C\u0435\u0441\u0442 \u0432 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0430\u0445.
    \u042D\u0442\u043E \u0441\u043F\u043E\u0434\u0432\u0438\u0433\u043B\u043E \u0432
    \u0441\u0432\u043E\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0441\u0438\u043B\u0435\u043D\u0438\u044E
    \u043F\u0430\u043D\u0438\u043A\u0438 \u0438 \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432,
    \u043D\u043E \u0438 \u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0443 \u0441\u043A\u0430\u0447\u043A\u0443
    \u0432\u043E\u0440\u043E\u0432\u0441\u0442\u0432\u0430 \u0432 \u0430\u043F\u0442\u0435\u043A\u0430\u0445
    \u0438 \u0440\u044B\u043D\u043A\u0430\u0445.\n\"\u0415\u0441\u043B\u0438 \u0431\u044B
    \u043C\u044B \u043C\u043E\u0433\u043B\u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C,
    \u0447\u0442\u043E \u043C\u043E\u0433\u043B\u043E \u0431\u044B\u0442\u044C \u0447\u0442\u043E-\u0442\u043E
    \u0445\u0443\u0436\u0435 \u0434\u0435\u0432\u044F\u043D\u043E\u0441\u0442\u044B\u0445,
    \u0442\u043E \u043C\u044B \u043A\u0430\u0442\u0438\u043C\u0441\u044F \u0432 \u043A\u0443\u0434\u0430
    \u0431\u043E\u043B\u0435\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0434\u044B\u0440\u0443, \u0447\u0435\u043C \u0432\u044B \u0434\u0443\u043C\u0430\u0435\u0442\u0435\"
    -- \u0437\u0430\u044F\u0432\u0438\u043B\u0430 \u0410\u043D\u043D\u0430 \u041C\u043E\u0440\u043E\u0437\u043E\u0432\u0430,
    \u0431\u044B\u0432\u0448\u0438\u0439 \u0447\u043B\u0435\u043D \u0441\u043E\u0432\u0435\u0442\u0430
    \u0412\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043F\u043E \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439 \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0435"
