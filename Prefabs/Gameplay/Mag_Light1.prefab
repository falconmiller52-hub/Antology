      m_Calls: []
  m_text: "\u041E \u0440\u043E\u0441\u0442\u0435 \u0446\u0435\u043D \u043D\u0430
    \u043C\u0435\u0445\u0430 \u043B\u0435\u0441\u043D\u044B\u0445 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u043E\u0432.
    \u0411\u0443\u0434\u0443\u0449\u0438\u0439 \u043A\u0440\u0438\u0437\u0438\u0441
    \u043F\u0443\u0448\u043D\u0438\u043D\u044B \u0438 \u0434\u0435\u0444\u0438\u0446\u0438\u0442
    \u043C\u0435\u0445\u043E\u0432 \u0431\u044B\u043B \u0432\u044B\u0437\u0432\u0430\u043D
    \u0440\u0435\u0437\u043A\u0438\u043C \u0441\u043A\u0430\u0447\u043A\u043E\u043C
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0443\u0442\u0435\u043F\u043B\u0435\u043D\u043D\u043E\u0439 \u043E\u0434\u0435\u0436\u0434\u044B
    \u0438 \u0434\u0430\u0436\u0435 \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F
    \u0434\u043E\u043C\u043E\u0432 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0433\u0443\u0441\u0442\u043E\u0439 \u0448\u0435\u0440\u0441\u0442\u0438.\n\u041F\u043E
    \u043E\u0446\u0435\u043D\u043A\u0430\u043C \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u043E\u0432,
    \u0440\u043E\u0441\u0442 \u0446\u0435\u043D \u043C\u043E\u0436\u0435\u0442 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C\u0441\u044F
    \u0434\u043E \u043D\u0430\u0447\u0430\u043B\u0430 \u043B\u0435\u0442\u0430, \u0435\u0441\u043B\u0438
    \u043F\u043E\u0433\u043E\u0434\u043D\u044B\u0435 \u0443\u0441\u043B\u043E\u0432\u0438\u044F
    \"\u043D\u0435 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u044B \u043C\u0435\u043D\u044F\u0442\u044C\u0441\u044F
    \u0432 \u043B\u0443\u0447\u0448\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443\""
  m_isRightToLeft: 0
