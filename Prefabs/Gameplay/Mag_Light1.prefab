      m_Calls: []
  m_text: "\u041A\u0440\u0443\u043F\u043D\u0430\u044F \u0430\u0432\u0430\u0440\u0438\u044F
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430 \u0432 \u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u0448\u0430\u0445\u0442\u0430\u0445\n4 \u0430\u043F\u0440\u0435\u043B\u044F
    \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u043D\u043E\u0447\u0438.
    \u0412 \u0445\u043E\u0434\u0435 \u0438\u043D\u0446\u0438\u0434\u0435\u043D\u0442\u0430
    \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u043B\u0438 \u0434\u043E 90
    \u0448\u0430\u0445\u0442\u0435\u0440\u043E\u0432 \u0438 \u043E\u043A\u043E\u043B\u043E
    15 \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u043F\u043E\u0433\u0438\u0431\u043B\u043E
    \u0432 \u0437\u0430\u0432\u0430\u043B\u0430\u0445\n\u041F\u043E\u043B\u0438\u0446\u0438\u044F
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0432\u044B\u044F\u0441\u043D\u044F\u0435\u0442
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435\n\u043F\u0440\u0438\u0447\u0438\u043D\u044B
    \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u044B. \u0412\u043F\u0440\u043E\u0447\u0435\u043C,
    \u0438\u043D\u043E\u0433\u0434\u0430 \u043F\u0440\u0430\u0432\u0434\u0430\n\u043B\u0435\u0436\u0438\u0442
    \u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438.\n\n"
