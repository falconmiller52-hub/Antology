      m_Calls: []
  m_text: "\u0422\u043E\u043B\u044C\u043A\u043E \u0437\u0430 \u0434\u0435\u043A\u0430\u0431\u0440\u044C
    \u0440\u0430\u0437\u043D\u0438\u0446\u0430 \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043F\u0440\u043E\u0435\u043A\u0442\u044B
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0430 7%, \u0432 \u0442\u043E
    \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u0440\u0430\u0437\u043D\u0438\u0446\u0430
    \u043A \u043A\u043E\u043D\u0446\u0443 \u043C\u0430\u0440\u0442\u0430 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u043B\u0430\u0441\u044C
    \u043A 15%. "
