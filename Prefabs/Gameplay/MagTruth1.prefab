  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041E\u0431 \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u0438
    \u0440\u0430\u0431\u043E\u0447\u0438\u0445 \u0447\u0430\u0441\u043E\u0432 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432
    \u043F\u0440\u0430\u0432\u043E\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043E\u0440\u0433\u0430\u043D\u043E\u0432 \u0433\u043B\u0430\u0441\u0438\u043B
    \u043F\u0440\u0438\u043A\u0430\u0437 \u043E\u0442 3 \u0430\u043F\u0440\u0435\u043B\u044F.
    \u0414\u043B\u044F \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u044B\u0445 \u0441\u043B\u0443\u0447\u0430\u0435\u0432
    \u0438 \u043C\u0430\u0441\u0441\u043E\u0432\u044B\u0445 \u043F\u043E\u0442\u0430\u0441\u043E\u0432\u043E\u043A,
    \u0431\u044B\u043B\u043E \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u043E \u0440\u0430\u0431\u043E\u0447\u0435\u0435
    \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \u0434\u043B\u044F
    \u043F\u043E\u043B\u0438\u0446\u0438\u0438, \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u043E
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u043E\u0445\u0440\u0430\u043D\u043D\u044B\u0445
    \u043F\u0443\u043D\u043A\u0442\u043E\u0432.\n\"\u0412\u0441\u0435 \u0438\u0434\u0435\u0442
    \u043F\u0440\u0435\u0436\u0434\u0435 \u0432\u0441\u0435\u0433\u043E \u043D\u0430
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435 \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u0412 \u043A\u043E\u043D\u0446\u0435 \u043A\u043E\u043D\u0446\u043E\u0432, \u043E\u0442
    \u044D\u0442\u043E\u0433\u043E \u0437\u0430\u0432\u0438\u0441\u044F\u0442 \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0442\u043E-\u0442\u043E \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E,
    \u0430 \u0432\u0441\u0435\""
  m_isRightToLeft: 0
