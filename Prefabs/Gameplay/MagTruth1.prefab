  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u2014 \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u043F\u043E\u0441\u043B\u0435
    \u044F\u0434\u0435\u0440\u043D\u043E\u0439 \u0437\u0438\u043C\u044B \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442
    \u044F\u0434\u0435\u0440\u043D\u0430\u044F \u0432\u0435\u0441\u043D\u0430. \u041D\u043E
    \u043F\u043E\u043A\u0430 \u0447\u0442\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435,
    \u0447\u0442\u043E \u0443 \u043D\u0430\u0441 \u0440\u0430\u0441\u0446\u0432\u0435\u0442\u0430\u0435\u0442
    \u2014 \u044D\u0442\u043E \u043E\u0447\u0435\u0440\u0435\u0434\u044C \u0437\u0430
    \u043A\u0430\u0440\u0442\u043E\u0447\u043A\u0430\u043C\u0438.\n\u2014 \u0420\u0430\u043D\u044C\u0448\u0435
    \u043B\u044E\u0434\u0438 \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u043E\u0435 \u043F\u043E\u0442\u0435\u043F\u043B\u0435\u043D\u0438\u0435.
    \u041D\u0443 \u0447\u0442\u043E, \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u044B
    \u0442\u0435\u043F\u0435\u0440\u044C?"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 901642eba4bffe64e8f4ee6be61200d7, type: 2}
