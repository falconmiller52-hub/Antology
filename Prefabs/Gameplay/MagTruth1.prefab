  m_text: "4 \u0430\u043F\u0440\u0435\u043B\u044F \u043F\u0440\u043E\u0448\u043B\u043E
    \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0441\u0443\u0434\u0435\u0431\u043D\u043E\u0435 \u0441\u043B\u0443\u0448\u0430\u043D\u0438\u0435
    \u043F\u043E \u0434\u0435\u043B\u0443 \"\u041B\u0435\u0441\u043D\u0438\u0447\u0435\u0433\u043E\".
    \u0412\u0435\u043B\u0435\u043C\u0438\u0440 \u0412\u043E\u0440\u043E\u0431\u044C\u0435\u0432,
    \u043F\u043E\u0445\u0438\u0442\u0438\u0432\u0448\u0438\u0439 \u043F\u043E \u043C\u0435\u043D\u044C\u0448\u0435\u0439
    \u043C\u0435\u0440\u0435 15 \u0434\u0435\u0442\u0435\u0439 \u0438\u0437 \u0434\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u0434\u043E\u043C\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0434\u0435\u0442\u0435\u0439
    \u0438\u0437 \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u0435\u043C\u0435\u0439,
    \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0435\u043D
    \u043A \u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0439 \u043A\u0430\u0437\u043D\u0438. "
