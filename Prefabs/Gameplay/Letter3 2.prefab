--- !u!114 &5837268011437832810
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5861888156689496523}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0414\u043E\u0440\u043E\u0433\u0438\u0435 \u0431\u0440\u0430\u0442\u044C\u044F
    \u0438 \u0441\u0451\u0441\u0442\u0440\u044B. \u0414\u043E\u0440\u043E\u0433\u0438\u0435
    \u0432\u0441\u0435, \u043A\u0442\u043E \u0441\u043B\u044B\u0448\u0438\u0442.\n\u042F
    \u043E\u0431\u0440\u0430\u0449\u0430\u044E\u0441\u044C \u043A \u0432\u0430\u043C
    \u0447\u0435\u0440\u0435\u0437 \u0440\u0430\u0434\u0438\u043E, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u0445\u0440\u0430\u043C \u043C\u043E\u0439 \u0437\u0430\u043A\u0440\u044B\u0442,
    \u0430 \u043C\u0435\u043D\u044F \u0434\u0435\u0440\u0436\u0430\u0442 \u0432 \u043F\u043E\u0434\u0432\u0430\u043B\u0435
    \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u0437\u0434\u0430\u043D\u0438\u044F. \u041E\u0431\u0440\u0430\u0449\u0430\u044E\u0442\u0441\u044F
    \u0441\u043E \u043C\u043D\u043E\u0439 \u0441\u043D\u043E\u0441\u043D\u043E \u2014
    \u043D\u0435 \u0431\u044C\u044E\u0442, \u043A\u043E\u0440\u043C\u044F\u0442.
    \u0411\u0443\u043C\u0430\u0433\u0443 \u0438 \u043A\u0430\u0440\u0430\u043D\u0434\u0430\u0448
    \u0434\u0430\u043B\u0438. \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C,
    \u043D\u0430\u0434\u0435\u044E\u0442\u0441\u044F, \u0447\u0442\u043E \u044F \u043D\u0430\u043F\u0438\u0448\u0443
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435. \u042F \u043F\u0438\u0448\u0443
    \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435.\n\u042F
    \u0445\u043E\u0447\u0443 \u043F\u043E\u0432\u0438\u043D\u0438\u0442\u044C\u0441\u044F.
    \u041D\u043E \u043D\u0435 \u043F\u0435\u0440\u0435\u0434 \u0432\u043B\u0430\u0441\u0442\u044C\u044E,
    \u0430 \u043F\u0435\u0440\u0435\u0434 \u0432\u0430\u043C\u0438.\n\u041C\u043D\u0435
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0438 \u0432\u044B\u0431\u043E\u0440.
    \u041E\u0442\u0434\u0430\u0442\u044C \u0441\u043F\u0438\u0441\u043A\u0438 \u0434\u0435\u0442\u0435\u0439,
    \u0438 \u043F\u0440\u0438\u044E\u0442 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u043F\u043E\u0434 \u043D\u0430\u0434\u0437\u043E\u0440\u043E\u043C
    \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430. \u041E\u0442\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0438 \u043F\u0440\u0438\u044E\u0442 \u0437\u0430\u043A\u0440\u043E\u044E\u0442,
    \u0430 \u0434\u0435\u0442\u0435\u0439 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442
    \u043F\u043E \u0442\u0440\u0443\u0434\u043E\u0432\u044B\u043C \u0441\u0435\u043C\u044C\u044F\u043C.
    \u041C\u043D\u0435 \u0441\u043A\u0430\u0437\u0430\u043B\u0438: \u0432\u0430\u0448\u0435
    \u0443\u043F\u0440\u044F\u043C\u0441\u0442\u0432\u043E \u0438\u043C \u0436\u0435
    \u0432\u043E \u0432\u0440\u0435\u0434.\n\u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C,
    \u0442\u0430\u043A \u0438 \u0435\u0441\u0442\u044C. \u041C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C, \u044F \u043E\u0431\u0440\u0451\u043A \u0438\u0445
    \u043D\u0430 \u0445\u0443\u0434\u0448\u0435\u0435, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u0443\u0431\u0435\u0440\u0435\u0447\u044C \u043E\u0442 \u043F\u043B\u043E\u0445\u043E\u0433\u043E.
    \u042F \u043D\u0435 \u0437\u043D\u0430\u044E. \u0413\u043E\u0441\u043F\u043E\u0434\u044C
    \u043D\u0435 \u0434\u0430\u043B \u043C\u043D\u0435 \u044F\u0441\u043D\u043E\u0441\u0442\u0438.
    \u042F \u043C\u043E\u043B\u0438\u043B\u0441\u044F \u2014 \u0438 \u043D\u0435
    \u0443\u0441\u043B\u044B\u0448\u0430\u043B \u043E\u0442\u0432\u0435\u0442\u0430.
    \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C, \u043E\u0442\u0432\u0435\u0442
    \u0431\u044B\u043B, \u0430 \u044F \u043D\u0435 \u0441\u0443\u043C\u0435\u043B
    \u0440\u0430\u0441\u0441\u043B\u044B\u0448\u0430\u0442\u044C. \u042F \u0441\u0442\u0430\u0440\u044B\u0439,
    \u0443\u0441\u0442\u0430\u0432\u0448\u0438\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A.
    \u041D\u0435 \u043F\u0440\u043E\u0440\u043E\u043A. \u041D\u0435 \u0433\u0435\u0440\u043E\u0439.\n\u042F
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0432 \u0441\u043F\u0438\u0441\u043A\u0430\u0445
    \u0438\u043C\u0435\u043D\u0430. \u0417\u0430 \u043A\u0430\u0436\u0434\u044B\u043C
    \u0438\u043C\u0435\u043D\u0435\u043C \u0441\u0442\u043E\u0438\u0442 \u0440\u0435\u0431\u0451\u043D\u043E\u043A.
    \u0417\u0430 \u043A\u0430\u0436\u0434\u044B\u043C \u0440\u0435\u0431\u0451\u043D\u043A\u043E\u043C
    \u2014 \u0441\u0432\u043E\u044F \u0441\u0443\u0434\u044C\u0431\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0440\u0435\u0448\u0430\u0442 \u0431\u0435\u0437 \u043D\u0435\u0433\u043E. \u042F
    \u043D\u0435 \u043C\u043E\u0433 \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u044C
    \u044D\u0442\u0438 \u0438\u043C\u0435\u043D\u0430 \u043B\u044E\u0434\u044F\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0434\u0435\u0442\u0438 \u2014 \u0441\u0442\u0440\u043E\u0447\u043A\u0430
    \u0432 \u0432\u0435\u0434\u043E\u043C\u043E\u0441\u0442\u0438. \u041D\u043E \u043E\u0442\u043A\u0430\u0437\u0430\u0432,
    \u044F, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u043E\u0431\u0440\u0451\u043A
    \u0438\u0445 \u043D\u0430 \u0442\u043E \u0436\u0435 \u0441\u0430\u043C\u043E\u0435,
    \u043D\u043E \u0442\u043E\u043B\u044C\u043A\u043E \u0431\u0435\u0437 \u043C\u0435\u043D\u044F
    \u0440\u044F\u0434\u043E\u043C.\n\u041B\u044E\u0431\u043E\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0434\u0435\u043B\u0430\u0435\u0442 \u043C\u0435\u043D\u044F \u0433\u0440\u0435\u0448\u043D\u0438\u043A\u043E\u043C.
    \u041E\u0442\u0434\u0430\u0442\u044C \u0437\u043D\u0430\u0447\u0438\u0442 \u0432\u0441\u0435
    \u0440\u0430\u0432\u043D\u043E \u0447\u0442\u043E \u043F\u0440\u0435\u0434\u0430\u0442\u044C.
    \u041D\u0435 \u043E\u0442\u0434\u0430\u0442\u044C \u2014 \u044D\u0442\u043E \u0443\u0436\u0435
    \u0433\u043E\u0440\u0434\u044B\u043D\u044F, \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043F\u043B\u0430\u0442\u044F\u0442 \u0434\u0435\u0442\u0438. \u042F \u0432\u044B\u0431\u0440\u0430\u043B
    \u0433\u043E\u0440\u0434\u044B\u043D\u044E. \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C,
    \u0432\u044B\u0431\u0440\u0430\u043B \u043D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E.\n\u042F
    \u043D\u0435 \u043F\u0440\u043E\u0448\u0443 \u0432\u0430\u0441 \u0441\u043F\u0430\u0441\u0442\u0438
    \u043C\u0435\u043D\u044F. \u042F \u043F\u0440\u043E\u0448\u0443, \u0440\u0430\u0441\u0441\u043A\u0430\u0436\u0438\u0442\u0435.
    \u041F\u0443\u0441\u0442\u044C \u0433\u043E\u0440\u043E\u0434 \u0440\u0435\u0448\u0438\u0442.
    \u041F\u0443\u0441\u0442\u044C \u043B\u044E\u0434\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u043B\u0443\u0448\u0430\u044E\u0442 \u0432\u0430\u0441 \u043F\u043E \u0432\u0435\u0447\u0435\u0440\u0430\u043C,
    \u0443 \u043F\u0435\u0447\u0435\u043A \u0438 \u0441\u0432\u0435\u0447\u0435\u0439,
    \u0443\u0441\u043B\u044B\u0448\u0430\u0442 \u0438 \u0441\u043A\u0430\u0436\u0443\u0442:
    \u043F\u0440\u0430\u0432 \u0431\u044B\u043B \u0441\u0442\u0430\u0440\u0438\u043A
    \u0438\u043B\u0438 \u043D\u0435\u0442. \u042F \u043F\u0440\u0438\u043C\u0443
    \u043B\u044E\u0431\u043E\u0439 \u043E\u0442\u0432\u0435\u0442. \u041C\u043D\u0435
    \u043D\u0435 \u0441\u0442\u0440\u0430\u0448\u043D\u043E \u0443\u043C\u0435\u0440\u0435\u0442\u044C.
    \u041C\u043D\u0435 \u0441\u0442\u0440\u0430\u0448\u043D\u043E \u0443\u043C\u0435\u0440\u0435\u0442\u044C,
    \u043D\u0435 \u0443\u0437\u043D\u0430\u0432, \u043F\u0440\u043E\u0441\u0442\u0438\u043B\u0438
    \u043B\u0438 \u043C\u0435\u043D\u044F \u0442\u0435, \u0440\u0430\u0434\u0438
    \u043A\u043E\u0433\u043E \u044F \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0442\u044C
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E.\n\u0418 \u0435\u0449\u0451.
    \u0415\u0441\u043B\u0438 \u043C\u0435\u043D\u044F \u043D\u0435 \u0441\u0442\u0430\u043D\u0435\u0442
    \u2014 \u043F\u043E\u0437\u0430\u0431\u043E\u0442\u044C\u0442\u0435\u0441\u044C
    \u043E \u0434\u0435\u0442\u044F\u0445. \u041D\u0435 \u043A\u043E\u043C\u0438\u0442\u0435\u0442.
    \u041D\u0435 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u044F.
    \u0412\u044B. \u041B\u044E\u0434\u0438. \u0421\u043E\u0441\u0435\u0434\u0438.
    \u0422\u0435, \u043A\u0442\u043E \u0435\u0449\u0451 \u043F\u043E\u043C\u043D\u0438\u0442,
    \u0447\u0442\u043E \u0434\u0435\u0442\u0438 \u2014 \u044D\u0442\u043E \u043D\u0435
    \u0440\u0435\u0441\u0443\u0440\u0441 \u0438 \u043D\u0435 \u043E\u0431\u0443\u0437\u0430.
    \u042D\u0442\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435,
    \u0447\u0442\u043E \u0443 \u043D\u0430\u0441 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C.\n\u0421
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E \u043A\u043E \u0432\u0441\u0435\u043C
    \u0432\u0430\u043C.\n\u041E\u0442\u0435\u0446 \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439."
