  m_text: "\u0414\u0432\u0430\u0434\u0446\u0430\u0442\u0438\u0442\u0440\u0451\u0445\u043B\u0435\u0442\u043D\u0438\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A \u0414\u0435\u043D\u0438\u0441 \u0425\u0440\u0430\u043C\u043E\u0432
    \u0438\u0437 \u043A\u0430\u0437\u0430\u0440\u043C\u044B \u043D\u0430 \u0421\u0435\u0432\u0435\u0440\u043D\u043E\u0439
    \u0441\u043E\u0431\u0440\u0430\u043B \u0440\u0430\u0431\u043E\u0447\u0438\u0439
    \u0442\u0435\u043F\u043B\u043E\u0432\u043E\u0439 \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440
    \u0438\u0437 \u0437\u0430\u043F\u0447\u0430\u0441\u0442\u0435\u0439 \u0442\u0440\u0451\u0445
    \u0441\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0445 \u0430\u0433\u0440\u0435\u0433\u0430\u0442\u043E\u0432.
    \u041F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C
    \u0436\u0438\u043B\u044C\u0446\u043E\u0432, \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0430
    \u0432 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u0438 \u043F\u043E\u0434\u043D\u044F\u043B\u0430\u0441\u044C
    \u0434\u043E \u043F\u043B\u044E\u0441 \u0434\u0432\u0435\u043D\u0430\u0434\u0446\u0430\u0442\u0438
    \u0433\u0440\u0430\u0434\u0443\u0441\u043E\u0432. \u0412\u043F\u0435\u0440\u0432\u044B\u0435
    \u0437\u0430 \u0434\u0432\u0430 \u043C\u0435\u0441\u044F\u0446\u0430 \u043B\u044E\u0434\u0438
    \u043C\u043E\u0433\u0443\u0442 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
    \u0432 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u0438 \u0431\u0435\u0437
    \u0432\u0435\u0440\u0445\u043D\u0435\u0439 \u043E\u0434\u0435\u0436\u0434\u044B."
