  blipSource: {fileID: 1884177698}
  voiceBlip: {fileID: 8300000, guid: 3fafad4924ab14f4c85983ecade15442, type: 3}
  voicePitch: 1
  typeSpeed: 0.04
  charsPerBlip: 2
  blocks:
  - lines:
    - "\u0417\u0434\u0430\u0440\u043E\u0432\u0430! \u041A\u0430\u043A \u0442\u0435\u0431\u0435
      \u043D\u043E\u0432\u043E\u0435 \u0440\u0430\u0431\u043E\u0447\u0435\u0435 \u043C\u0435\u0441\u0442\u043E?"
    - "\u0420\u0430\u0437 \u0443\u0436 \u0442\u044B \u0443 \u043D\u0430\u0441 \u043D\u043E\u0432\u044B\u0439
      \u0440\u0430\u0434\u0438\u0439\u0449\u0438\u043A, \u0442\u043E \u0434\u0430\u0432\u0430\u0439
      \u0440\u0430\u0441\u0441\u043A\u0430\u0436\u0443 \u0447\u0442\u043E \u0442\u0443\u0442
      \u0434\u0430 \u043A\u0430\u043A..."
    - "\u0422\u0432\u043E\u044F \u0440\u0430\u0431\u043E\u0442\u0430 \u0442\u0435\u043F\u0435\u0440\u044C
      \u0441\u043E\u0441\u0442\u043E\u0438\u0442 \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E\u0431\u044B
      \u0438\u043D\u0444\u0443 \u0438 \u043A\u043B\u0435\u043F\u0430\u0442\u044C
      \u0441\u044E\u0436\u0435\u0442\u044B \u0434\u043B\u044F \u0440\u0430\u0434\u0438\u043E
      \u044D\u0444\u0438\u0440\u0430"
    - "\u0418\u0449\u0435\u0448\u044C, \u043F\u0438\u0448\u0435\u0448\u044C \u0438
      \u043F\u0443\u0441\u043A\u0430\u0435\u0448\u044C \u0432 \u044D\u0444\u0438\u0440,
      \u043A\u0430\u043A \u0434\u0432\u0430 \u043F\u0430\u043B\u044C\u0446\u0430!"
    waitForEvent: 0
    unlockZone: 0
  - lines:
    - "\u0412\u0438\u0434\u0438\u0448\u044C \u043F\u0438\u0441\u044C\u043C\u0430
      \u043D\u0430 \u043B\u043E\u0442\u043A\u0435? \u042D\u0442\u043E \u043D\u0430\u0448\u0438
      \u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u0438 \u043F\u0440\u0438\u0441\u044B\u043B\u0430\u044E\u0442
      \u0442\u0435\u0431\u0435"
    - "\u0422\u0430\u043C \u0438\u043D\u043E\u0433\u0434\u0430 \u0441\u0442\u043E\u043B\u044C\u043A\u043E
      \u0432\u0441\u0435\u0433\u043E... \u041D\u043E \u043E\u043D\u043E \u0438 \u043F\u043E\u043D\u044F\u0442\u043D\u043E,
      \u043D\u0430\u0440\u043E\u0434 \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0432\u0441\u0435
      \u043A\u0430\u043A \u0435\u0441\u0442\u044C"
    - "\u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 \u043F\u043E\u0447\u0438\u0442\u0430\u0442\u044C
      \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C \u0438 \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
      \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0444\u0440\u0430\u0437\u044B,
      \u043E\u043D\u0438 \u0442\u0435\u0431\u0435 \u043F\u0440\u0438\u0433\u043E\u0434\u044F\u0442\u0441\u044F"
    waitForEvent: 1
    unlockZone: 1
  - lines:
    - "\u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0435 \u0447\u0442\u0438\u0432\u043E,
      \u0434\u0430?"
    waitForEvent: 0
    unlockZone: 0
  - lines:
    - "\u0425\u043E\u0440\u043E\u0448\u043E, \u0434\u0430\u0432\u0430\u0439-\u043A\u0430
      \u0442\u0435\u043F\u0435\u0440\u044C \u043F\u0440\u043E\u0447\u0442\u0435\u043C
      \u0433\u0430\u0437\u0435\u0442\u043A\u0443, \u0432 \u043D\u0438\u0445 \u043E\u0431\u044B\u0447\u043D\u043E
      \u0431\u043E\u043B\u0435\u0435-\u043C\u0435\u043D\u0435\u0435 \u0432\u0441\u0435
      \u0433\u0440\u0430\u043C\u043E\u0442\u043D\u043E"
    - "\u041E\u0442\u043A\u0440\u043E\u0439 \u043A\u0430\u043A\u0443\u044E-\u043D\u0438\u0431\u0443\u0434\u044C
      \u0433\u0430\u0437\u0435\u0442\u0443 \u0438 \u0442\u043E\u0447\u043D\u043E
      \u0442\u0430\u043A \u0436\u0435 \u0432\u044B\u0434\u0435\u043B\u0438 \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
      \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0435"
    waitForEvent: 1
    unlockZone: 2
  - lines:
    - "\u041D\u0443 \u0432\u043E\u0442, \u043D\u0435 \u0442\u0430\u043A \u0443\u0436
      \u0438 \u0441\u043B\u043E\u0436\u043D\u043E, \u0441\u043A\u0430\u0436\u0438? "
    waitForEvent: 0
    unlockZone: 0
  - lines:
    - "\u041A\u0441\u0442\u0430\u0442\u0438, \u043F\u043E \u0440\u0430\u0434\u0438\u043E
      \u043A\u0440\u0443\u0442\u044F\u0442 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
      \u043C\u0443\u0437\u044B\u043A\u0443"
    - "\u0418\u043D\u043E\u0433\u0434\u0430 \u043C\u043E\u0436\u043D\u043E \u0443\u0441\u043B\u044B\u0448\u0430\u0442\u044C
      \u043E\u0447\u0435\u043D\u044C \u043C\u043D\u043E\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0433\u043E"
    - "\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u0432\u044B\u043B\u043E\u0432\u0438\u0442\u044C
      \u0441\u0438\u0433\u043D\u0430\u043B... "
    - "\u041D\u0443-\u043A\u0430 \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439
      \u043D\u0430\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0447\u0430\u0441\u0442\u043E\u0442\u044B,
      \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u043A\u0440\u0443\u0442\u0438!"
    waitForEvent: 3
    unlockZone: 4
  - lines:
    - "\u041A\u0430\u043A \u0434\u0432\u0430 \u043F\u0430\u043B\u044C\u0446\u0430!"
    waitForEvent: 0
    unlockZone: 0
  - lines:
    - "\u041F\u043E \u0440\u0430\u0434\u0438\u043E \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C
      \u043E\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044C \u0434\u0440\u0443\u0433\u0438\u0445
      \u043B\u044E\u0434\u0435\u0439"
    - "\u0422\u0430\u043C \u0438\u043D\u043E\u0433\u0434\u0430 \u0441\u0442\u043E\u043B\u044C\u043A\u043E
      \u0432\u0441\u0435\u0433\u043E... \u041D\u043E \u043E\u043D\u043E \u0438 \u043F\u043E\u043D\u044F\u0442\u043D\u043E,
      \u043D\u0430\u0440\u043E\u0434 \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0432\u0441\u0435
      \u043A\u0430\u043A \u0435\u0441\u0442\u044C"
    - "\u0414\u043B\u044F \u043D\u0430\u0447\u0430\u043B\u0430 \u0432\u043A\u043B\u044E\u0447\u0438
      \u043C\u0438\u043A\u0440\u043E\u0444\u043E\u043D \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0441\u044C,
      \u0441 \u043A\u0435\u043C \u0445\u043E\u0447\u0435\u0448\u044C \u0431\u0440\u0430\u0442\u044C
      \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E..."
    - "\u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 \u0432\u044B\u0437\u0432\u0430\u0442\u044C
      \u041A\u0438\u0440\u0438\u043B\u043B\u0430 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0430,
      \u043E\u043D \u0433\u043B\u0430\u0432\u0430 \u0434\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u0438,
      \u043D\u0435\u0434\u0430\u0432\u043D\u043E \u0445\u043E\u0434\u0438\u043B\u0438
      \u043D\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0443 \u043A \u0434\u0440\u0443\u0433\u043E\u043C\u0443
      \u0433\u043E\u0440\u043E\u0434\u0443"
    - "\u041F\u043E\u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0439 \u043A\u0430\u043A
      \u0442\u0430\u043C \u0432\u0441\u0435 \u043F\u0440\u043E\u0448\u043B\u043E"
    waitForEvent: 4
    unlockZone: 5
  - lines:
    - "\u0421\u0443\u043F\u0435\u0440! \u0421 \u0440\u0430\u0434\u0438\u043E \u0442\u044B
      \u043E\u0431\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F \u0443\u043C\u0435\u0435\u0448\u044C,
      \u044D\u0442\u043E \u0445\u043E\u0440\u043E\u0448\u043E. \u041A\u0430\u043A
      \u043D\u0430\u0441\u0447\u0435\u0442 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0430?"
    waitForEvent: 0
    unlockZone: 0
  - lines:
    - "\u0412 \u043D\u0435\u043C \u0442\u044B \u0431\u0443\u0434\u0435\u0448\u044C
      \u043F\u0438\u0441\u0430\u0442\u044C \u0442\u0435\u043A\u0441\u0442 \u0434\u043B\u044F
      \u0441\u044E\u0436\u0435\u0442\u043E\u0432 \u0438 \u043F\u0443\u0441\u043A\u0430\u0442\u044C
      \u0438\u0445 \u0432 \u044D\u0444\u0438\u0440. "
    - "\u0421\u043F\u0435\u0440\u0432\u0430 \u043D\u0443\u0436\u043D\u043E \u0432\u044B\u0431\u0440\u0430\u0442\u044C
      \u0442\u0435\u043C\u0443 \u0434\u043B\u044F \u0441\u044E\u0436\u0435\u0442\u0430
      \u043D\u0430 \u043F\u043E\u0432\u0435\u0441\u0442\u043A\u0443 \u043D\u0430
      \u0434\u043D\u044F, \u0430 \u043F\u043E\u0442\u043E\u043C \u0448\u0430\u0433
      \u0437\u0430 \u0448\u0430\u0433\u043E\u043C \u0432\u044B\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0442\u044C
      \u0442\u0435\u043A\u0441\u0442"
    - "\u0412\u043A\u043B\u044E\u0447\u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440
      \u0438 \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C
      \u0442\u0435\u043A\u0441\u0442"
    - "\u0415\u0441\u043B\u0438 \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442
      \u043A\u0430\u043A\u0438\u0445-\u0442\u043E \u0434\u0430\u043D\u043D\u044B\u0445,
      \u0442\u043E \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 \u043F\u0435\u0440\u0435\u0447\u0438\u0442\u0430\u0442\u044C
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u0435\u0449\u0435 \u0440\u0430\u0437!"
    waitForEvent: 2
    unlockZone: 3
  - lines:
    - "\u0412 \u0446\u0435\u043B\u043E\u043C \u0432\u0441\u0435! \u0412\u0438\u0434\u0438\u0448\u044C,
      \u043D\u0435 \u0442\u0430\u043A \u0443\u0436 \u0438 \u0441\u043B\u043E\u0436\u043D\u043E?"
    - "\u0412 \u0434\u0435\u043D\u044C \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E
      \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C \u043F\u043E 3
      \u0441\u044E\u0436\u0435\u0442\u0430, \u044D\u0442\u043E \u0442\u0432\u043E\u044F
      \u043A\u0432\u043E\u0442\u0430"
    - "\u041E\u0441\u0432\u0430\u0438\u0432\u0430\u0439\u0441\u044F, \u0440\u0430\u0431\u043E\u0442\u0430\u0439,
      \u043D\u0443 \u0430 \u044F \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435
      \u043E\u0442\u0432\u043B\u0435\u043A\u0430\u044E..."
    waitForEvent: 0
    unlockZone: 0
  enableOnlyInFirstDay: 1
