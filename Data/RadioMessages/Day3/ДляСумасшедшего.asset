  m_Name: "\u0414\u043B\u044F\u0421\u0443\u043C\u0430\u0441\u0448\u0435\u0434\u0448\u0435\u0433\u043E"
  m_EditorClassIdentifier: Assembly-CSharp::RadioMessage
  targetFrequencyA: 0.639
  targetFrequencyB: 0.91
  dayNumber: 3
  lines:
  - "\u0421\u041B\u0423\u0428\u0410\u0419\u0422\u0415! \u0421\u041B\u0423\u0428\u0410\u0419\u0422\u0415
    \u0412\u0421\u0415! ...  "
  - "\u042F \u041F\u0415\u0420\u0415\u0425\u0412\u0410\u0422\u0418\u041B \u0427\u0410\u0421\u0422\u041E\u0422\u0423!
    \u0421\u041B\u042B\u0428\u0418\u0422\u0415 \u041C\u0415\u041D\u042F?! ... \u041E\u041D\u0418
    \u0418\u0414\u0423\u0422! ... "
  - "\u041D\u043E\u0447\u044C\u044E! \u041A\u0430\u0436\u0434\u0443\u044E \u043D\u043E\u0447\u044C!
    \u0418\u0437 \u043C\u0435\u0442\u0435\u043B\u0438! ... \u0412\u044B \u0434\u0443\u043C\u0430\u0435\u0442\u0435
    \u2014 \u044D\u0442\u043E \u0432\u0435\u0442\u0435\u0440?! "
  - "\u042D\u0422\u041E \u041D\u0415 \u0412\u0415\u0422\u0415\u0420! ... \u041F\u0440\u0438\u0437\u0440\u0430\u043A\u0438!
    \u0411\u0435\u043B\u044B\u0435! \u0411\u0435\u0437 \u043B\u0438\u0446! ... "
  - "\u042F \u0432\u0438\u0434\u0435\u043B! \u0421\u0432\u043E\u0438\u043C\u0438
    \u0433\u043B\u0430\u0437\u0430\u043C\u0438! \u0423 \u0412\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445
    \u0432\u043E\u0440\u043E\u0442! ... "
  - "\u0421\u0442\u043E\u044F\u0442 \u0432 \u0441\u043D\u0435\u0433\u0443 \u0438
    \u0441\u043C\u043E\u0442\u0440\u044F\u0442! \u0411\u0415\u0417 \u0413\u041B\u0410\u0417
    \u2014 \u041D\u041E \u0421\u041C\u041E\u0422\u0420\u042F\u0422!... "
  - "\u041C\u043D\u0435 \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u0432\u0435\u0440\u0438\u0442!
    \u041D\u0418\u041A\u0422\u041E! ... \u0421\u043E\u0441\u0435\u0434 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u2014 \u0442\u044B \u0431\u043E\u043B\u044C\u043D\u043E\u0439! "
  - "\u042F \u043D\u0435 \u0431\u043E\u043B\u044C\u043D\u043E\u0439! \u042F \u0415\u0414\u0418\u041D\u0421\u0422\u0412\u0415\u041D\u041D\u042B\u0419
    \u0417\u0414\u041E\u0420\u041E\u0412\u042B\u0419!  ... \u041E\u043D\u0438 \u0437\u0430\u0431\u0438\u0440\u0430\u044E\u0442
    \u043B\u044E\u0434\u0435\u0439! "
  - "\u0422\u0435\u043B\u0430! \u0422\u0435\u043B\u0430 \u0438\u0437 \u043C\u043E\u0440\u0433\u0430!
    \u0417\u0430\u0447\u0435\u043C, \u0434\u0443\u043C\u0430\u0435\u0442\u0435?!
    ... \u041E\u041D\u0418 \u0418\u0425 \u0421\u0422\u0410\u0412\u042F\u0422! \u0412
    \u0441\u043D\u0435\u0433! "
  - "\u041A\u0430\u043A \u0441\u043E\u043B\u0434\u0430\u0442! \u0410\u0420\u041C\u0418\u042F
    \u041C\u0401\u0420\u0422\u0412\u042B\u0425!  ... \u0421\u043B\u0443\u0448\u0430\u0439\u0442\u0435!
    \u0421\u041B\u0423\u0428\u0410\u0419\u0422\u0415! "
  - "... \u0412\u0441\u0435\u043C \u043D\u0430 \u043A\u0440\u044B\u0448\u0438! \u0412\u0421\u0415\u041C!
    \u0411\u0435\u0440\u0438\u0442\u0435 \u0440\u0443\u0436\u044C\u044F! \u0411\u0435\u0440\u0438\u0442\u0435
    \u0447\u0442\u043E \u0435\u0441\u0442\u044C! ... \u0412\u0438\u043B\u044B! \u0422\u043E\u043F\u043E\u0440\u044B!
    \u041B\u043E\u043F\u0430\u0442\u044B! "
  - "... \u041D\u0430 \u043A\u0440\u044B\u0448\u0438! \u041E\u043D\u0438 \u0438\u0434\u0443\u0442
    \u0441 \u0441\u0435\u0432\u0435\u0440\u0430! \u0412\u0421\u0415\u0413\u0414\u0410
    \u0421 \u0421\u0415\u0412\u0415\u0420\u0410! ... \u0421\u0442\u0440\u0435\u043B\u044F\u0442\u044C!
    \u041F\u043E \u0431\u0435\u043B\u044B\u043C! "
  - "\u041F\u043E \u0442\u0435\u043C, \u043A\u0442\u043E \u0431\u0435\u0437 \u043B\u0438\u0446\u0430!
    ... \u041D\u0435 \u0436\u0430\u043B\u0435\u0439\u0442\u0435 \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432!
    \u041F\u0410\u0422\u0420\u041E\u041D\u042B \u041F\u041E\u0422\u041E\u041C \u041D\u0410\u0419\u0414\u0401\u0422\u0415!
    \u0416\u0418\u0417\u041D\u042C \u2014 \u041D\u0415\u0422!  "
  - "... \u042F \u041C\u0443\u0441\u044E \u0441\u0432\u043E\u044E \u0432\u0438\u0434\u0435\u043B.
    \u0421\u0440\u0435\u0434\u0438 \u043D\u0438\u0445. \u041C\u0443\u0440\u043A\u0430
    \u0443\u043C\u0435\u0440\u043B\u0430 \u0432 \u043E\u043A\u0442\u044F\u0431\u0440\u0435. "
  - "... \u0421\u0442\u043E\u044F\u043B\u0430 \u0438 \u0441\u043C\u043E\u0442\u0440\u0435\u043B\u0430
    \u043D\u0430 \u043C\u0435\u043D\u044F. \u041C\u0443\u0441\u0435\u043D\u044C\u043A\u0430
    \u043C\u043E\u044F.  ... "
  - "\u041D\u041E \u042D\u0422\u041E \u041D\u0415 \u041E\u041D\u0410! \u042D\u0422\u041E
    \u041E\u0411\u041E\u041B\u041E\u0427\u041A\u0410! \u041F\u0423\u0421\u0422\u0410\u042F!
    ... "
  - "\u041D\u0410 \u041A\u0420\u042B\u0428\u0418! \u0421\u0415\u0413\u041E\u0414\u041D\u042F
    \u041D\u041E\u0427\u042C\u042E! \u0412\u0421\u0415! ... \u042F \u0411\u0423\u0414\u0423
    \u041D\u0410 \u041A\u0420\u042B\u0428\u0415 \u0411\u0410\u0420\u0410\u041A\u0410
    \u0412\u041E\u0421\u0415\u041C\u042C! ... "
  - "\u041A\u0422\u041E \u0421\u041E \u041C\u041D\u041E\u0419 \u2014 \u041F\u0420\u0418\u0425\u041E\u0414\u0418\u0422\u0415!
    ... \u041A\u0422\u041E \u041D\u0415 \u041F\u0420\u0418\u0414\u0401\u0422 \u2014
    \u041F\u0415\u041D\u042F\u0419\u0422\u0415 \u041D\u0410 \u0421\u0415\u0411\u042F!"
