  m_Script: {fileID: 11500000, guid: 941934f3df2ce514c9c169b90e032722, type: 3}
  m_Name: "\u041F\u043E\u0431\u0435\u0433"
  m_EditorClassIdentifier: Assembly-CSharp::RadioMessage
  targetFrequencyA: 0.935
  targetFrequencyB: 0.694
  dayNumber: 3
  lines:
  - "\u0422\u0438\u0445\u043E. \u0422\u0438\u0445\u043E. ... \u0418\u0434\u0443\u0442
    \u0434\u0432\u043E\u0435. \u041E\u043D \u043F\u043E\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435.
    ... "
  - "\u0412\u0435\u0434\u0443\u0442 \u043A \u0421\u0435\u0432\u0435\u0440\u043D\u043E\u043C\u0443.
    \u041A \u0441\u043A\u043B\u0430\u0434\u0430\u043C. ... \u0417\u0430\u0447\u0435\u043C
    \u043A \u0441\u043A\u043B\u0430\u0434\u0430\u043C? ... \u041D\u0435 \u0437\u043D\u0430\u044E.
    \u0422\u0430\u043C \u043F\u0443\u0441\u0442\u043E. "
  - "\u041D\u0435\u0442 \u043B\u044E\u0434\u0435\u0439. \u041D\u0435\u0442 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u0435\u0439.
    ... [\u043F\u0430\u0443\u0437\u0430] ... \u0421\u043A\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430\u0441? ... \u0421\u0435\u043C\u0435\u0440\u043E. \u0415\u0449\u0451
    \u0442\u0440\u043E\u0435 \u0443 \u0437\u0430\u0431\u043E\u0440\u0430. "
  - "... \u0425\u0432\u0430\u0442\u0438\u0442? ... \u041A\u043E\u043D\u0432\u043E\u0439
    \u2014 \u0434\u0432\u043E\u0435. \u0425\u0432\u0430\u0442\u0438\u0442. ... [\u0448\u0430\u0433\u0438
    \u0431\u044B\u0441\u0442\u0440\u0435\u0435] "
  - "... \u041F\u043E\u0434\u043E\u0436\u0434\u0438\u0442\u0435. \u041F\u043E\u0434\u043E\u0436\u0434\u0438\u0442\u0435.
    ... \u041E\u043D\u0438 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438\u0441\u044C.
    \u0423 \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u043A\u043E\u0440\u043F\u0443\u0441\u0430.
    ... \u0417\u0430\u0432\u043E\u0434\u044F\u0442 \u0432\u043D\u0443\u0442\u0440\u044C?
    ... "
  - "\u041D\u0435\u0442. \u0421\u0442\u043E\u044F\u0442. \u041E\u0434\u0438\u043D
    \u0438\u0437 \u043A\u043E\u043D\u0432\u043E\u0439\u043D\u044B\u0445 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043F\u043E \u0440\u0430\u0446\u0438\u0438. ... [\u043F\u0430\u0443\u0437\u0430] "
  - "... \u041C\u0430\u043B\u044C\u0447\u0438\u0448\u043A\u0430 \u043D\u0430 \u043D\u043E\u0433\u0430\u0445
    \u0435\u043B\u0435 \u0441\u0442\u043E\u0438\u0442. \u041F\u043E\u0445\u043E\u0436\u0435,
    \u0431\u0438\u043B\u0438. ... [\u0442\u0438\u0445\u043E] ... \u041B\u0430\u0434\u043D\u043E.
    \u041A\u043E\u0433\u0434\u0430 \u0437\u0430\u0439\u0434\u0443\u0442 \u0432\u043D\u0443\u0442\u0440\u044C
    \u2014 \u043E\u0431\u0445\u043E\u0434\u0438\u043C \u0441\u043B\u0435\u0432\u0430. "
  - "\u0412\u0430\u0441\u044C\u043A\u0430 \u2014 \u0441\u043F\u0440\u0430\u0432\u0430,
    \u0447\u0435\u0440\u0435\u0437 \u043E\u043A\u043D\u043E. ... \u0411\u0435\u0437
    \u043A\u0440\u043E\u0432\u0438. \u0421\u043B\u044B\u0448\u0438\u0442\u0435? \u0411\u0435\u0437
    \u043A\u0440\u043E\u0432\u0438. \u041E\u0433\u043B\u0443\u0448\u0438\u0442\u044C,
    \u0437\u0430\u0431\u0440\u0430\u0442\u044C, \u0443\u0439\u0442\u0438. ... "
  - "\u0410 \u0435\u0441\u043B\u0438 \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u0441\u044F
    \u0431\u0435\u0437 \u043A\u0440\u043E\u0432\u0438? ... \u041F\u043E\u043B\u0443\u0447\u0438\u0442\u0441\u044F.
    \u0414\u043E\u043B\u0436\u043D\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C\u0441\u044F.
    ... [\u043F\u0430\u0443\u0437\u0430] ... \u041F\u043E\u0448\u043B\u0438. \u041E\u043D\u0438
    \u0437\u0430\u0445\u043E\u0434\u044F\u0442. "
  - "\u0414\u0430\u0432\u0430\u0439. \u0414\u0430\u0432\u0430\u0439. \u0422\u0438\u0445\u2014
    ... [\u0413\u0420\u041E\u0425\u041E\u0422] ... \u041B\u041E\u0416\u0418\u0421\u042C!
    ."
  - ".. \u0427\u0422\u041E \u042D\u0422\u041E?! ... \u0412\u0417\u0420\u042B\u0412!
    \u041E\u0422 \u0421\u041A\u041B\u0410\u0414\u041E\u0412! ... [\u043A\u0440\u0438\u043A\u0438,
    \u0442\u043E\u043F\u043E\u0442] ... \u041D\u0410\u0417\u0410\u0414! \u0412\u0421\u0415
    \u041D\u0410\u0417\u0410\u0414!"
  - ".. \u041A\u0430\u043A\u043E\u0433\u043E... \u0447\u0442\u043E \u0440\u0432\u0430\u043D\u0443\u043B\u043E?!
    ... \u041D\u0415 \u0417\u041D\u0410\u042E! \u0411\u0415\u0416\u0418\u041C! "
  - "... \u0410 \u0438\u043D\u0436\u0435\u043D\u0435\u0440?! ... [\u043F\u0430\u0443\u0437\u0430,
    \u0442\u044F\u0436\u0451\u043B\u043E\u0435 \u0434\u044B\u0445\u0430\u043D\u0438\u0435]
    ... \u0422\u0430\u043C... \u0442\u0430\u043C \u0432\u0441\u0451 \u0433\u043E\u0440\u0438\u0442.
    \u0422\u0440\u0435\u0442\u0438\u0439 \u043A\u043E\u0440\u043F\u0443\u0441. "
  - "\u0412\u0441\u0451. ... [\u0431\u0435\u0433, \u0445\u0440\u0443\u0441\u0442
    \u0441\u043D\u0435\u0433\u0430] ... \u0418\u0445 \u0442\u0430\u043C... \u043E\u043D\u0438
    \u0436\u0435 \u0432\u043D\u0443\u0442\u0440\u0438 \u0431\u044B\u043B\u0438...
    ... \u0411\u0415\u0416\u0418\u041C! \u0421\u0415\u0419\u0427\u0410\u0421 \u041D\u0410\u0411\u0415\u0413\u0423\u0422!"
  lineIntelKeys:
