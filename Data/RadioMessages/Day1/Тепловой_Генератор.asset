  m_Script: {fileID: 11500000, guid: 941934f3df2ce514c9c169b90e032722, type: 3}
  m_Name: "\u0422\u0435\u043F\u043B\u043E\u0432\u043E\u0439_\u0413\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440"
  m_EditorClassIdentifier: Assembly-CSharp::RadioMessage
  targetFrequencyA: 0.262
  targetFrequencyB: 0.583
  dayNumber: 1
  lines:
  - "\u0410\u043B\u043B\u043E, \u0441\u043B\u044B\u0448\u0438\u0448\u044C? "
  - "\u042D\u0442\u043E \u0421\u0435\u0432\u0435\u0440\u043D\u0430\u044F, \u0431\u0430\u0440\u0430\u043A
    \u0448\u0435\u0441\u0442\u044C."
  - " \u0413\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440 \u0432\u0430\u0448 \u0445\u0432\u0430\u043B\u0451\u043D\u044B\u0439.
    \u0425\u0440\u0430\u043C\u043E\u0432\u0441\u043A\u0438\u0439... \u0414\u0430,
    \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442. \u0422\u0435\u043F\u043B\u043E.
    \u041D\u0435 \u0441\u043F\u043E\u0440\u044E. "
  - "\u041D\u043E \u0434\u044B\u0448\u0430\u0442\u044C \u043D\u0435\u0447\u0435\u043C.
    ... [\u043A\u0430\u0448\u0435\u043B\u044C] "
  - "\u0412\u0447\u0435\u0440\u0430 \u041B\u044E\u0434\u0430 \u0441 \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u044D\u0442\u0430\u0436\u0430 \u0443\u043F\u0430\u043B\u0430 \u043F\u0440\u044F\u043C\u043E
    \u0432 \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0435. ... \u041E\u0431\u043C\u043E\u0440\u043E\u043A. "
  - "... \u041F\u043E\u0437\u0430\u0432\u0447\u0435\u0440\u0430 \u2014 \u0434\u0435\u0434
    \u041A\u0443\u0437\u044C\u043C\u0438\u0447. \u0421\u0438\u0434\u0435\u043B, \u0441\u0438\u0434\u0435\u043B
    \u2014 \u0438 \u043D\u0430\u0431\u043E\u043A. ... "
  - "\u0414\u0443\u043C\u0430\u043B\u0438 \u2014 \u043F\u043E\u043C\u0435\u0440.
    \u041D\u0435\u0442. \u041F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F."
  - " ... \u0423\u0433\u0430\u0440 \u044D\u0442\u043E. \u0423\u0433\u0430\u0440.
    ... \u0412\u044B\u0442\u044F\u0436\u043A\u0438 \u043D\u0435\u0442. \u041E\u043A\u043D\u0430
    \u0437\u0430\u043A\u043E\u043B\u043E\u0447\u0435\u043D\u044B \u2014 \u043C\u044B
    \u0436\u0435 \u0441\u0430\u043C\u0438 \u0437\u0430\u043A\u043E\u043B\u043E\u0442\u0438\u043B\u0438,
    \u043E\u0442 \u0445\u043E\u043B\u043E\u0434\u0430."
  - "\u0410 \u0442\u0435\u043F\u0435\u0440\u044C \u0447\u0442\u043E \u2014 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u044C?
    ... \u041E\u0442\u043A\u0440\u043E\u0435\u0448\u044C \u2014 \u0437\u0430\u043C\u0451\u0440\u0437\u043D\u0435\u0448\u044C.
    \u041D\u0435 \u043E\u0442\u043A\u0440\u043E\u0435\u0448\u044C \u2014 \u0443\u0433\u043E\u0440\u0438\u0448\u044C.
    ... [\u043A\u0430\u0448\u0435\u043B\u044C] ... \u041A\u0440\u0430\u0441\u0438\u0432\u044B\u0439
    \u0432\u044B\u0431\u043E\u0440, \u0434\u0430?"
  - "\u041A\u0440\u0430\u0441\u0438\u0432\u044B\u0439 \u0432\u044B\u0431\u043E\u0440,
    \u0434\u0430?"
  - "\u041A\u0440\u0430\u0441\u0438\u0432\u044B\u0439 \u0432\u044B\u0431\u043E\u0440,
    \u0434\u0430?"
  - "\u0412\u044B \u043F\u0435\u0440\u0435\u0434\u0430\u0439\u0442\u0435 \u0425\u0440\u0430\u043C\u043E\u0432\u0443
    \u2014 \u043F\u0443\u0441\u0442\u044C \u043F\u0440\u0438\u0434\u0451\u0442, \u043F\u043E\u0434\u044B\u0448\u0438\u0442
    \u0441 \u043D\u0430\u043C\u0438. ... \u041E\u0434\u043D\u0443 \u043D\u043E\u0447\u044C.
    \u0412\u0441\u0435\u0433\u043E \u043E\u0434\u043D\u0443. "
  - "\u041F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u043C, \u043A\u0430\u043A \u043E\u043D
    \u0443\u0442\u0440\u043E\u043C \u0432\u0441\u0442\u0430\u043D\u0435\u0442. ...
    \u0415\u0441\u043B\u0438 \u0432\u0441\u0442\u0430\u043D\u0435\u0442."
  lineIntelKeys:
  - {fileID: 11400000, guid: 231d0875f5453a74abae86cf574ed711, type: 2}
  voiceBlip: {fileID: 8300000, guid: 3fafad4924ab14f4c85983ecade15442, type: 3}
  voicePitch: 1
  senderName: A man
  description: "\u041F\u0435\u0440\u0435\u0445\u0432\u0430\u0447\u0435\u043D\u043D\u043E\u0435
    \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435"
  hasBeenPlayed: 0
