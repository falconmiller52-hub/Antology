  m_Script: {fileID: 11500000, guid: 941934f3df2ce514c9c169b90e032722, type: 3}
  m_Name: "\u0414\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u044F"
  m_EditorClassIdentifier: Assembly-CSharp::RadioMessage
  targetFrequencyA: 0.3
  targetFrequencyB: 0
  dayNumber: 1
  lines:
  - "\u0411\u0430\u0437\u0430, \u044D\u0442\u043E \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432.
    \u0414\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u044F. ..."
  - "\u041F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u044B \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u044B.
    \u0421\u043E\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043D\u043E.
    ... \u0423\u0433\u043E\u043B\u044C \u043D\u0430 \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u044B.
    \u041A\u0430\u043A \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B\u0438."
  - "\u041F\u0435\u0440\u0432\u0430\u044F \u043F\u0430\u0440\u0442\u0438\u044F \u0447\u0435\u0440\u0435\u0437
    \u0434\u0432\u0435 \u043D\u0435\u0434\u0435\u043B\u0438... \u0415\u0441\u043B\u0438
    \u0434\u043E\u0440\u043E\u0433\u0443 \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0451\u0442.
    ..."
  - "\u0418 \u0435\u0449\u0435... \u041C\u044B \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B\u0438
    \u0441 \u0438\u0445 \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0430\u043C\u0438.
    \u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043D\u0438\u044F.
    ..."
  - "\u041E\u043D\u0438 \u0445\u043E\u0434\u044F\u0442 \u0434\u0430\u043B\u0435\u043A\u043E.
    \u0414\u0430\u043B\u044C\u0448\u0435 \u043D\u0430\u0448\u0438\u0445. \u041D\u0430
    \u044E\u0433, \u043D\u0430 \u0437\u0430\u043F\u0430\u0434. ... \u0417\u043D\u0430\u0435\u0448\u044C,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u0432\u0438\u0434\u0435\u043B\u0438?"
  - "\u041D\u0438\u0447\u0435\u0433\u043E. ... \u0412 \u043F\u0440\u044F\u043C\u043E\u043C.
    \u041D\u0438\u0447\u0435\u0433\u043E. \u041D\u0438\u043A\u043E\u0433\u043E. \u041D\u0438
    \u043E\u0434\u0438\u043D \u0433\u043E\u0440\u043E\u0434 \u043D\u0435 \u0432\u044B\u0436\u0438\u043B..."
  - "\u041A\u0435\u0434\u0440\u043E\u0432\u044B\u0439 \u043F\u0443\u0441\u0442. \u041E\u043D\u0438
    \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u043B\u0438. \u0421\u043E\u0441\u043D\u043E\u0432\u043A\u0430
    \u2014 \u0442\u043E \u0436\u0435 \u0441\u0430\u043C\u043E\u0435. ... \u041F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u044B\u0439
    \u2014 \u0437\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u043D\u0435 \u0441\u0442\u0430\u043B\u0438."
  - "\u041D\u0430\u0441 \u0434\u0432\u043E\u0435. \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434
    \u0438 \u041E\u0437\u0451\u0440\u043D\u043E\u0435. \u0418 \u0432\u0441\u0451.
    ... \u0412 \u0440\u0430\u0434\u0438\u0443\u0441\u0435 \u0434\u0432\u0443\u0445\u0441\u043E\u0442
    \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432 \u2014 \u043C\u044B
    \u043E\u0434\u043D\u0438."
  - "\u041F\u0435\u0440\u0435\u0434\u0430\u0439\u0442\u0435 \u0432\u0435\u0440\u0445\u0443\u0448\u043A\u0435.
    \u041F\u0443\u0441\u0442\u044C \u0440\u0435\u0448\u0430\u044E\u0442, \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
    \u043B\u044E\u0434\u044F\u043C \u0438\u043B\u0438 \u043D\u0435\u0442."
  - "\u042F \u0431\u044B \u043D\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u043B.
    ... \u041F\u0430\u043D\u0438\u043A\u0430 \u043D\u0430\u0447\u043D\u0435\u0442\u0441\u044F,
    \u0430 \u0432\u0441\u0435 \u0438\u0442\u0430\u043A \u0445\u0435\u0440\u043E\u0432\u043E..."
  lineIntelKeys:
  - {fileID: 11400000, guid: f81bcce6480dfba4e8f1b3bf0103faef, type: 2}
