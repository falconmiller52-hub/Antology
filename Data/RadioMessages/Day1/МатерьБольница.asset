  m_Script: {fileID: 11500000, guid: 941934f3df2ce514c9c169b90e032722, type: 3}
  m_Name: "\u041C\u0430\u0442\u0435\u0440\u044C\u0411\u043E\u043B\u044C\u043D\u0438\u0446\u0430"
  m_EditorClassIdentifier: Assembly-CSharp::RadioMessage
  targetFrequencyA: 0.293
  targetFrequencyB: 0.744
  dayNumber: 1
  lines:
  - "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E, \u043A\u0442\u043E \u044D\u0442\u043E
    \u0441\u043B\u044B\u0448\u0438\u0442. ... "
  - "\u041C\u043D\u0435 \u0441\u043A\u0430\u0437\u0430\u043B\u0438 \u2014 \u0433\u043E\u0432\u043E\u0440\u0438
    \u0432 \u044D\u0442\u0443 \u0448\u0442\u0443\u043A\u0443, \u043C\u043E\u0436\u0435\u0442,
    \u043A\u0442\u043E \u0443\u0441\u043B\u044B\u0448\u0438\u0442. ... [\u043F\u0430\u0443\u0437\u0430]
    ... "
  - "\u0423 \u043C\u0435\u043D\u044F \u0434\u0432\u043E\u0435. \u041D\u0430\u0441\u0442\u044F
    \u0438 \u0412\u0430\u043D\u0435\u0447\u043A\u0430. \u0421\u0435\u043C\u044C \u0438
    \u0447\u0435\u0442\u044B\u0440\u0435. ... \u041E\u043D\u0438 \u0431\u043E\u043B\u0435\u044E\u0442.
    \u0423\u0436\u0435 \u043D\u0435\u0434\u0435\u043B\u044E. ... "
  - "\u0416\u0430\u0440. \u041E\u0431\u0430 \u0433\u043E\u0440\u044F\u0442. \u0422\u0440\u044F\u043F\u043A\u0438
    \u043C\u043E\u043A\u0440\u044B\u0435 \u043A\u043B\u0430\u0434\u0443 \u2014 \u0432\u044B\u0441\u044B\u0445\u0430\u044E\u0442
    \u0437\u0430 \u043C\u0438\u043D\u0443\u0442\u0443. ... "
  - "\u0412\u0430\u043D\u0435\u0447\u043A\u0430 \u0443\u0436\u0435 \u043D\u0435 \u043F\u043B\u0430\u0447\u0435\u0442.
    \u041E\u043D \u043F\u0440\u043E\u0441\u0442\u043E \u043B\u0435\u0436\u0438\u0442
    \u0438 \u0441\u043C\u043E\u0442\u0440\u0438\u0442 \u0432 \u043F\u043E\u0442\u043E\u043B\u043E\u043A.
    ... \u041D\u0430\u0441\u0442\u044F \u0441\u0442\u043E\u043D\u0435\u0442. \u0412\u0441\u0451
    \u0432\u0440\u0435\u043C\u044F. \u0414\u0430\u0436\u0435 \u0432\u043E \u0441\u043D\u0435.
    ... "
  - "\u042F \u0445\u0443\u0436\u0435 \u044D\u0442\u043E\u0433\u043E \u0437\u0432\u0443\u043A\u0430
    \u043D\u0438\u0447\u0435\u0433\u043E \u0432 \u0436\u0438\u0437\u043D\u0438 \u043D\u0435
    \u0441\u043B\u044B\u0448\u0430\u043B\u0430. ... [\u043F\u0430\u0443\u0437\u0430]
    ... "
  - "\u042F \u043D\u043E\u0441\u0438\u043B\u0430 \u0438\u0445 \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0443.
    \u041D\u0430 \u0440\u0443\u043A\u0430\u0445. \u041E\u0431\u043E\u0438\u0445.
    ... \u0427\u0435\u0442\u044B\u0440\u0435 \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u0430.
    ... \u0422\u0430\u043C \u0441\u043A\u0430\u0437\u0430\u043B\u0438 \u2014 \u043C\u0435\u0441\u0442
    \u043D\u0435\u0442."
  - " ... \u042F \u0433\u043E\u0432\u043E\u0440\u044E \u2014 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435
    \u0445\u043E\u0442\u044F \u0431\u044B. \u041F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435.
    ... \u0421\u043A\u0430\u0437\u0430\u043B\u0438 \u2014 \u043C\u0435\u0441\u0442
    \u043D\u0435\u0442. \u0414\u0432\u0435\u0440\u044C \u0437\u0430\u043A\u0440\u044B\u043B\u0438.
    ... [\u0442\u0438\u0448\u0438\u043D\u0430] ... "
  - "\u042F \u0441\u0442\u043E\u044F\u043B\u0430 \u0441 \u043D\u0438\u043C\u0438
    \u043D\u0430 \u043A\u0440\u044B\u043B\u044C\u0446\u0435 \u0438 \u043D\u0435 \u0437\u043D\u0430\u043B\u0430,
    \u043A\u0443\u0434\u0430 \u0438\u0434\u0442\u0438. ... \u041A\u0443\u0434\u0430
    \u043C\u043D\u0435 \u0438\u0434\u0442\u0438? ... [\u043F\u0430\u0443\u0437\u0430]
    ... "
