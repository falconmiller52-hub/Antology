  m_Script: {fileID: 11500000, guid: 941934f3df2ce514c9c169b90e032722, type: 3}
  m_Name: "\u041C\u0430\u043C\u0430\u0414\u043E\u043A\u0442\u043E\u0440\u0430"
  m_EditorClassIdentifier: Assembly-CSharp::RadioMessage
  targetFrequencyA: 0.079
  targetFrequencyB: 0.707
  dayNumber: 2
  lines:
  - "\u041C\u0430\u043C. ... \u042F \u0437\u043D\u0430\u044E, \u0442\u044B \u043D\u0435
    \u0441\u043B\u044B\u0448\u0438\u0448\u044C. \u0422\u044B \u0434\u0430\u043B\u0435\u043A\u043E. "
  - "\u0418\u043B\u0438 \u0442\u0435\u0431\u044F \u043D\u0435\u0442. \u042F \u043D\u0435
    \u0437\u043D\u0430\u044E. ... \u041D\u043E \u043C\u043D\u0435 \u0431\u043E\u043B\u044C\u0448\u0435
    \u043D\u0435 \u0441 \u043A\u0435\u043C. ... [\u043F\u0430\u0443\u0437\u0430] "
  - "... \u042F \u0432 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0435. \u0422\u0440\u0435\u0442\u0438\u0439
    \u043C\u0435\u0441\u044F\u0446. ... \u041A\u0430\u0436\u0434\u044B\u0439 \u0434\u0435\u043D\u044C
    \u043E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435. "
  - "\u041E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435. ... \u041F\u0440\u0438\u0445\u043E\u0434\u044F\u0442.
    \u041A\u0430\u0448\u0435\u043B\u044C. \u0416\u0430\u0440. \u041F\u043E\u0442\u043E\u043C
    \u2014 \u0440\u0443\u043A\u0438 \u043D\u0435\u043C\u0435\u044E\u0442. \u041F\u043E\u0442\u043E\u043C
    \u2014 \u043D\u043E\u0433\u0438. ... "
  - "\u041F\u043E\u0442\u043E\u043C \u043B\u0435\u0436\u0430\u0442 \u0438 \u0441\u043C\u043E\u0442\u0440\u044F\u0442
    \u0432 \u043F\u043E\u0442\u043E\u043B\u043E\u043A. \u0414\u044B\u0448\u0430\u0442
    \u0432\u0441\u0451 \u0440\u0435\u0436\u0435. ... \u041F\u043E\u0442\u043E\u043C
    \u043D\u0435 \u0434\u044B\u0448\u0430\u0442. ... [\u043F\u0430\u0443\u0437\u0430] "
  - "... \u0423 \u0432\u0441\u0435\u0445 \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E.
    \u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u0443 \u0432\u0441\u0435\u0445.
    \u041E\u0434\u0438\u043D \u0438 \u0442\u043E\u0442 \u0436\u0435 \u043D\u0430\u0431\u043E\u0440.
    ... \u041A\u0430\u0448\u0435\u043B\u044C. \u0416\u0430\u0440. \u041E\u043D\u0435\u043C\u0435\u043D\u0438\u0435. "
  - "\u041E\u0442\u043A\u0430\u0437. ... \u041A\u0430\u043A \u043F\u043E \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u044E.
    \u041F\u044F\u0442\u044C-\u0441\u0435\u043C\u044C \u0434\u043D\u0435\u0439 \u2014
    \u0438 \u0432\u0441\u0451. ... [\u0433\u043E\u043B\u043E\u0441 \u0442\u0438\u0448\u0435]
    ... "
  - "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E, \u0447\u0442\u043E \u044D\u0442\u043E.
    \u041D\u0435 \u0433\u0440\u0438\u043F\u043F. \u041D\u0435 \u043F\u043D\u0435\u0432\u043C\u043E\u043D\u0438\u044F.
    \u041D\u0438\u0447\u0435\u0433\u043E, \u0447\u0442\u043E \u044F \u0443\u0447\u0438\u043B.
    ... "
  - "\u0410\u043D\u0442\u0438\u0431\u0438\u043E\u0442\u0438\u043A\u0438 \u043D\u0435
    \u043F\u043E\u043C\u043E\u0433\u0430\u044E\u0442. \u041D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442. ... [\u043F\u0430\u0443\u0437\u0430]
    ... \u0412\u0447\u0435\u0440\u0430 \u0443\u043C\u0435\u0440\u043B\u0438 \u0442\u0440\u043E\u0435. "
  - "\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u2014 \u0434\u0432\u043E\u0435 \u043A
    \u0443\u0442\u0440\u0443. \u0415\u0449\u0451 \u0447\u0435\u0442\u0432\u0435\u0440\u043E
    \u2014 \u043A \u0432\u0435\u0447\u0435\u0440\u0443, \u044F \u0434\u0443\u043C\u0430\u044E.
    ... "
  - "\u042F \u0434\u0443\u043C\u0430\u044E. \u042F \u0443\u0436\u0435 \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F
    \u0434\u0443\u043C\u0430\u0442\u044C, \u043A\u0442\u043E \u043A \u0432\u0435\u0447\u0435\u0440\u0443.
    ... \u041F\u043E \u0433\u043B\u0430\u0437\u0430\u043C \u0432\u0438\u0434\u043D\u043E.
    \u041A\u043E\u0433\u0434\u0430 \u0441\u0442\u0435\u043A\u043B\u0435\u043D\u0435\u044E\u0442
    \u2014 \u0437\u043D\u0430\u0447\u0438\u0442, \u0441\u043A\u043E\u0440\u043E.
    ... [\u043F\u0430\u0443\u0437\u0430] ... "
  - "\u0425\u043E\u0447\u0443 \u0443\u0439\u0442\u0438, \u043C\u0430\u043C. ... \u041D\u0435
    \u0438\u0437 \u0436\u0438\u0437\u043D\u0438. \u0418\u0437 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0430.
    \u041F\u0440\u043E\u0441\u0442\u043E \u0443\u0439\u0442\u0438. \u0421\u043D\u044F\u0442\u044C
    \u0445\u0430\u043B\u0430\u0442. \u0417\u0430\u043A\u0440\u044B\u0442\u044C \u0434\u0432\u0435\u0440\u044C. "
  - "\u041D\u0435 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F.
    ... \u041D\u043E \u041B\u0451\u0448\u043A\u0430. \u041B\u0451\u0448\u043A\u0430
    \u0442\u0430\u043C. ... \u041E\u043D \u043D\u0430 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u0439
    \u043A\u043E\u0439\u043A\u0435 \u043E\u0442 \u0431\u043E\u043B\u044C\u043D\u044B\u0445. "
  - "\u041E\u043D \u0441\u0430\u043C \u0443\u0436\u0435 \u0435\u043B\u0435 \u0445\u043E\u0434\u0438\u0442,
    \u043D\u043E \u043D\u0435 \u0443\u0445\u043E\u0434\u0438\u0442. ... \u042F \u043D\u0435
    \u043C\u043E\u0433\u0443 \u0435\u0433\u043E \u0431\u0440\u043E\u0441\u0438\u0442\u044C.
    \u041E\u043D \u0431\u044B \u043C\u0435\u043D\u044F \u043D\u0435 \u0431\u0440\u043E\u0441\u0438\u043B.
    ... [\u043F\u0430\u0443\u0437\u0430] ... \u041C\u0430\u043C, \u0447\u0442\u043E
    \u043C\u043D\u0435 \u0434\u0435\u043B\u0430\u0442\u044C? "
  - ".. \u041E\u0441\u0442\u0430\u0442\u044C\u0441\u044F \u0438 \u0441\u043E\u0439\u0442\u0438
    \u0441 \u0443\u043C\u0430? ... \u0418\u043B\u0438 \u0443\u0439\u0442\u0438 \u0438
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F?
    ... [\u0442\u0438\u0448\u0438\u043D\u0430] "
  - "... \u041B\u0430\u0434\u043D\u043E. \u041B\u0430\u0434\u043D\u043E. \u042F \u043E\u0441\u0442\u0430\u043D\u0443\u0441\u044C.
    ... "
  - "\u042F \u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0442\u044B \u044D\u0442\u043E
    \u0441\u043A\u0430\u0436\u0435\u0448\u044C."
  lineIntelKeys:
