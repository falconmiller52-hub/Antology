  m_Script: {fileID: 11500000, guid: 941934f3df2ce514c9c169b90e032722, type: 3}
  m_Name: "\u041C\u0430\u043C\u0430\u0414\u043E\u043A\u0442\u043E\u0440\u0430 2"
  m_EditorClassIdentifier: Assembly-CSharp::RadioMessage
  targetFrequencyA: 0.079
  targetFrequencyB: 0.441
  dayNumber: 2
  lines:
  - "\u041F\u0435\u0442\u0440\u043E\u0432\u0438\u0447. \u041F\u0435\u0442\u0440\u043E\u0432\u0438\u0447,
    \u0442\u044B \u043D\u0430 \u0441\u0432\u044F\u0437\u0438?"
  - ".. \u0414\u0430, \u0441\u043B\u044B\u0448\u0443. \u041F\u043B\u043E\u0445\u043E
    \u0441\u043B\u044B\u0448\u0443, \u043D\u043E \u0434\u0430\u0432\u0430\u0439.
    ... \u0422\u044B \u0436\u0435 \u043D\u0430 \u0421\u0435\u0432\u0435\u0440\u043D\u043E\u043C
    \u0432\u044B\u0435\u0437\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0448\u044C,
    \u0434\u0430? \u0423 \u0432\u0430\u0441 \u0447\u0442\u043E \u0442\u0430\u043C
    \u2014 \u0441\u0442\u0440\u043E\u0439\u043A\u0430?"
  - " \u0421 \u0447\u0435\u0433\u043E \u0432\u0437\u044F\u043B? ..."
  - " \u0421 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043C\u0438\u043C\u043E
    \u043C\u043E\u0435\u0433\u043E \u0431\u0430\u0440\u0430\u043A\u0430 \u043A\u0430\u0436\u0434\u0443\u044E
    \u043D\u043E\u0447\u044C \u0438\u0434\u0443\u0442 \u0433\u0440\u0443\u0437\u043E\u0432\u0438\u043A\u0438.
    \u041A\u0430\u0436\u0434\u0443\u044E \u043D\u043E\u0447\u044C, \u041F\u0435\u0442\u0440\u043E\u0432\u0438\u0447.
    \u0412 \u0434\u0432\u0430, \u0432 \u0442\u0440\u0438 \u0447\u0430\u0441\u0430. "
  - "... \u041D\u0443, \u043C\u043E\u0436\u0435\u0442, \u043F\u043E\u0441\u0442\u0430\u0432\u043A\u0438.
    ... "
  - "\u041A\u0430\u043A\u0438\u0435 \u043F\u043E\u0441\u0442\u0430\u0432\u043A\u0438
    \u0432 \u0442\u0440\u0438 \u0447\u0430\u0441\u0430 \u043D\u043E\u0447\u0438?
    \u041A\u0443\u0434\u0430? ... "
  - "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E. \u042F \u043D\u0430 \u0440\u0430\u0437\u0433\u0440\u0443\u0437\u043A\u0435,
    \u043D\u0435 \u043D\u0430 \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u0430\u0445.
    ... \u0410 \u0447\u0442\u043E \u0440\u0430\u0437\u0433\u0440\u0443\u0436\u0430\u0435\u0448\u044C?
    ... . "
  - "\u0411\u0435\u0442\u043E\u043D\u043D\u044B\u0435 \u043F\u043B\u0438\u0442\u044B.
    \u0410\u0440\u043C\u0430\u0442\u0443\u0440\u0443. \u0422\u0440\u0443\u0431\u044B
    \u2014 \u0442\u043E\u043B\u0441\u0442\u044B\u0435, \u0432\u043E\u0442 \u0442\u0430\u043A\u0438\u0435.
    ... "
  - "\u0412\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u044B\u0435?"
  - ".. \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C. \u041E\u0442\u043A\u0443\u0434\u0430
    \u044F \u0437\u043D\u0430\u044E. \u0422\u0440\u0443\u0431\u044B \u0438 \u0442\u0440\u0443\u0431\u044B.
    ... "
  - "\u041A\u0443\u0434\u0430 \u0441\u0433\u0440\u0443\u0436\u0430\u0435\u0442\u0435? "
  - "... \u041D\u0430 \u043F\u043B\u043E\u0449\u0430\u0434\u043A\u0443. \u0422\u0430\u043C
    \u0434\u0430\u043B\u044C\u0448\u0435 \u2014 \u043D\u0435 \u043F\u0443\u0441\u043A\u0430\u044E\u0442.
    \u0417\u0430\u0431\u043E\u0440. \u041E\u0445\u0440\u0430\u043D\u0430. \u041D\u0435
    \u043D\u0430\u0448\u0438 \u2014 \u0434\u0440\u0443\u0433\u0438\u0435. "
  - "... \u0427\u0451\u0440\u043D\u044B\u0435 \u043A\u0443\u0440\u0442\u043A\u0438? "
  - "... \u0414\u0430..."
  - "\u0413\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440\u044B \u0432\u043E\u0437\u044F\u0442.
    \u0411\u043E\u043B\u044C\u0448\u0438\u0435. \u042F \u0442\u0430\u043A\u0438\u0445
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B.
    ... \u0415\u0441\u043B\u0438 \u0431\u044B \u043E\u0434\u0438\u043D \u0442\u0430\u043A\u043E\u0439
    \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440 \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0432 \u043D\u0430\u0448 \u0440\u0430\u0439\u043E\u043D \u2014 \u043C\u044B
    \u0431\u044B \u0437\u0430\u0431\u044B\u043B\u0438 \u043F\u0440\u043E \u0445\u043E\u043B\u043E\u0434. "
  - "... \u0410 \u0438\u0445 \u0442\u0443\u0434\u0430 \u2014 \u0442\u0440\u0438 \u0448\u0442\u0443\u043A\u0438
    \u0437\u0430 \u043D\u0435\u0434\u0435\u043B\u044E. \u0422\u0440\u0438. ... [\u043F\u0430\u0443\u0437\u0430] "
  - "... \u0418 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B. \u042F\u0449\u0438\u043A\u0438
    \u0431\u0435\u0437 \u043C\u0430\u0440\u043A\u0438\u0440\u043E\u0432\u043A\u0438.
    \u041C\u043D\u043E\u0433\u043E. \u041E\u0447\u0435\u043D\u044C \u043C\u043D\u043E\u0433\u043E.
    ... \u0412 \u0433\u043E\u0440\u043E\u0434 \u0438\u0434\u0451\u0442 \u2014 \u043A\u0440\u043E\u0445\u0438.
    \u0410 \u0442\u0443\u0434\u0430 \u2014 \u0433\u0440\u0443\u0437\u043E\u0432\u0438\u043A\u0430\u043C\u0438.
    ... "
  - "\u041F\u0435\u0442\u0440\u043E\u0432\u0438\u0447, \u0442\u044B \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C,
    \u0447\u0442\u043E \u044D\u0442\u043E? ... [\u043F\u0430\u0443\u0437\u0430]"
  - ".. \u041E\u043D\u0438 \u0441\u0442\u0440\u043E\u044F\u0442 \u0441\u0435\u0431\u0435
    \u043D\u043E\u0440\u0443. \u0422\u0451\u043F\u043B\u0443\u044E, \u0441\u044B\u0442\u0443\u044E,
    \u0441 \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440\u0430\u043C\u0438
    \u0438 \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u0435\u0439. ...
    \u0410 \u043C\u044B \u043D\u0430\u0432\u0435\u0440\u0445\u0443 \u2014 \u043A\u0430\u043A
    \u0445\u043E\u0442\u0438\u0442\u0435."
  - "\u042F \u043D\u0435 \u043F\u0430\u0440\u0430\u043D\u043E\u0438\u043A. \u042F
    \u0431\u0440\u0438\u0433\u0430\u0434\u0438\u0440. \u042F \u0443\u043C\u0435\u044E
    \u0441\u0447\u0438\u0442\u0430\u0442\u044C \u0431\u0435\u0442\u043E\u043D \u0438
    \u0430\u0440\u043C\u0430\u0442\u0443\u0440\u0443.  "
  - "\u0418 \u044F \u0442\u0435\u0431\u0435 \u0433\u043E\u0432\u043E\u0440\u044E
    \u2014 \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u0442\u0443\u0434\u0430
    \u0443\u0432\u0435\u0437\u043B\u0438, \u043C\u043E\u0436\u043D\u043E \u0434\u0432\u0430
    \u0431\u0430\u0440\u0430\u043A\u0430 \u043E\u0442\u0441\u0442\u0440\u043E\u0438\u0442\u044C.
    \u0421 \u043D\u0443\u043B\u044F. ... \u041D\u043E \u043D\u0435\u0442. \u0411\u0430\u0440\u0430\u043A\u0438
    \u0433\u043D\u0438\u044E\u0442. \u0410 \u0431\u0435\u0442\u043E\u043D \u0435\u0434\u0435\u0442
    \u0432 \u043D\u043E\u0447\u044C. \u0417\u0430 \u0437\u0430\u0431\u043E\u0440.
    \u041F\u043E\u0434 \u0437\u0435\u043C\u043B\u044E. ..."
  - "\u0421\u043B\u0443\u0448\u0430\u0439, \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0439.
    \u041C\u043D\u0435 \u0435\u0449\u0451 \u0441\u043C\u0435\u043D\u0443 \u0441\u0442\u043E\u044F\u0442\u044C. "
  - "... \u041B\u0430\u0434\u043D\u043E. \u041D\u043E \u0442\u044B \u043F\u043E\u0434\u0443\u043C\u0430\u0439.
    ... \u0418 \u0435\u0441\u043B\u0438 \u0440\u0435\u0448\u0438\u0448\u044C \u2014
    \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438, \u0447\u0442\u043E \u0437\u0430
    \u0442\u0435\u043C \u0437\u0430\u0431\u043E\u0440\u043E\u043C. "
