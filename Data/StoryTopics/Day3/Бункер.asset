  m_Name: "\u0411\u0443\u043D\u043A\u0435\u0440"
  m_EditorClassIdentifier: Assembly-CSharp::StoryTopic
  topicTitle: "\u0411\u0443\u043D\u043A\u0435\u0440"
  topicDescription: ...
  blocks:
  - blockLabel: 
    phraseOptions:
    - text: "\u0412 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u044E \u0433\u0430\u0437\u0435\u0442\u044B
        \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u043E \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0435
        \u043F\u0438\u0441\u044C\u043C\u043E \u043E\u0442 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
        \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0432\u0448\u0435\u0433\u043E\u0441\u044F
        \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u043C \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u0438.
        \u0410\u0432\u0442\u043E\u0440 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
        \u0447\u0442\u043E \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B\u044B
        \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0439 \u0412\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
        \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
        \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442\u0441\u044F
        \u0437\u0430\u0434\u043D\u0438\u043C \u0447\u0438\u0441\u043B\u043E\u043C,
        \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
        \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432 \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u044E\u0442\u0441\u044F
        \u0443\u0437\u043A\u0438\u043C \u043A\u0440\u0443\u0433\u043E\u043C \u0438\u0437
        \u0442\u0440\u0451\u0445 \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0430
        \u043A\u043E\u043C\u0438\u0442\u0435\u0442 \u0441\u043D\u0430\u0431\u0436\u0435\u043D\u0438\u044F
        \u2014 \u0448\u0438\u0440\u043C\u0430. \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
        \u0431\u0430\u0437\u044B \u043A \u043F\u0438\u0441\u044C\u043C\u0443 \u043D\u0435
        \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u043E. \u041D\u043E \u0435\u0441\u043B\u0438
        \u0445\u043E\u0442\u044F \u0431\u044B \u0447\u0430\u0441\u0442\u044C \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
        \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
        \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
        \u2014 \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u043E \u0442\u0435\u0445,
        \u043A\u0442\u043E \u043D\u0430\u043C\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442,
        \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043C\u0435\u043D\u044C\u0448\u0435,
        \u0447\u0435\u043C \u043D\u0430\u043C \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442
        \u0434\u0443\u043C\u0430\u0442\u044C."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 1
    - text: "\u0412 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u044E \u0433\u0430\u0437\u0435\u0442\u044B
        \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u043E \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0435
        \u043F\u0438\u0441\u044C\u043C\u043E \u043E\u0442 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
        \u043D\u0430\u0437\u0432\u0430\u0432\u0448\u0435\u0433\u043E\u0441\u044F
        \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u043C \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u0438.
        \u041F\u0440\u043E\u0442\u043E\u043A\u043E\u043B\u044B, \u043F\u043E \u0435\u0433\u043E
        \u0441\u043B\u043E\u0432\u0430\u043C, \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442\u0441\u044F.
        \u041A\u043E\u043C\u0438\u0442\u0435\u0442 \u0441\u043D\u0430\u0431\u0436\u0435\u043D\u0438\u044F
        \u2014 \u0448\u0438\u0440\u043C\u0430. \u0420\u0435\u0448\u0435\u043D\u0438\u044F
        \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u0443\u0437\u043A\u0438\u0439
        \u043A\u0440\u0443\u0433 \u0438\u0437 \u0442\u0440\u0451\u0445 \u0447\u0435\u043B\u043E\u0432\u0435\u043A.
        \u0418\u043C\u0451\u043D \u0430\u0432\u0442\u043E\u0440 \u043D\u0435 \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
        \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
        \u043D\u0435 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442,
        \u043F\u043E\u0434\u043F\u0438\u0441\u0438 \u043D\u0435 \u0441\u0442\u0430\u0432\u0438\u0442.
        \u0417\u0430\u0442\u043E \u0438\u043D\u0442\u0440\u0438\u0433\u0443\u0435\u0442:
        \xAB\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u043C\u044B \u043A\u0443\u0434\u0430
        \u043C\u0435\u043D\u044C\u0448\u0435 \u0437\u043D\u0430\u0435\u043C \u043E
        \u0442\u0435\u0445, \u043A\u043E\u0433\u043E \u043D\u0435\u043B\u044C\u0437\u044F
        \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C\xBB. \u0417\u0432\u0443\u0447\u0438\u0442
        \u0437\u043B\u043E\u0432\u0435\u0449\u0435. \u0410 \u0435\u0441\u043B\u0438
        \u0443\u0431\u0440\u0430\u0442\u044C \u0442\u0435\u0430\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
        \u2014 \u0430\u043D\u043E\u043D\u0438\u043C\u043A\u0430 \u0431\u0435\u0437
        \u0435\u0434\u0438\u043D\u043E\u0433\u043E \u0444\u0430\u043A\u0442\u0430,
        \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0430\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
        \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
        \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u0432 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u0438,
        \u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u2014 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
        \u044D\u0442\u043E \u0434\u043B\u044F \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438."
      factionAPoints: 0
      factionBPoints: 1
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 2
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u041F\u044F\u0442\u043E\u0433\u043E \u0430\u043F\u0440\u0435\u043B\u044F
        \u0440\u0430\u0434\u0438\u043E\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C
        \u0415. \u0412. \u0415\u0440\u0448\u043E\u0432 \u043F\u0435\u0440\u0435\u0445\u0432\u0430\u0442\u0438\u043B
        \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u043E\u0432,
        \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E
        \u043C\u0435\u0436\u0434\u0443 \u0432\u044B\u0441\u043E\u043A\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u043C\u0438
        \u043B\u0438\u0446\u0430\u043C\u0438 \u0433\u043E\u0440\u043E\u0434\u0430.
        \u0412 \u0437\u0430\u043F\u0438\u0441\u0438 \u2014 \u0441\u043B\u043E\u0432\u0430
        \u043E \u0441\u0440\u043E\u043A\u0430\u0445 \xAB\u043D\u0435 \u0431\u043E\u043B\u044C\u0448\u0435
        \u0433\u043E\u0434\u0430, \u043B\u0438\u0431\u043E \u0442\u043E\u0433\u043E
        \u043C\u0435\u043D\u044C\u0448\u0435\xBB, \u043E \u043F\u043B\u0430\u043D\u0435
        \xAB\u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u043A\u0438\xBB,
        \u0432\u0441\u0442\u0443\u043F\u0430\u044E\u0449\u0435\u043C \u0432 \u0441\u0438\u043B\u0443,
        \u043E \xAB\u043F\u0435\u0440\u0435\u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
        \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432\xBB, \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0443\u044E\u0449\u0435\u043C
        \xAB\u043D\u0430\u043C\u043D\u043E\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0435
        \u0448\u0430\u043D\u0441\u043E\u0432 \u043D\u0430 \u0432\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0435\xBB.
        \u041F\u0435\u0440\u0435\u0445\u0432\u0430\u0442 \u0441\u043E\u0432\u043F\u0430\u043B
        \u0441 \u0437\u0430\u043A\u0440\u044B\u0442\u044B\u043C \u0441\u043E\u0432\u0435\u0449\u0430\u043D\u0438\u0435\u043C
        \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430.
        \u0415\u0440\u0448\u043E\u0432 \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043D.
        \u0415\u0433\u043E \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435
        \u043A\u043E\u043D\u0444\u0438\u0441\u043A\u043E\u0432\u0430\u043D\u043E.
        \u0427\u0442\u043E \u0441 \u043D\u0438\u043C \u0441\u0435\u0439\u0447\u0430\u0441
        \u2014 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E
        \u043E\u0434\u043D\u043E: \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0443\u0441\u043B\u044B\u0448\u0430\u0432\u0448\u0438\u0439
        \u0447\u0443\u0436\u043E\u0439 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440,
        \u043B\u0438\u0448\u0438\u043B\u0441\u044F \u0441\u0432\u043E\u0431\u043E\u0434\u044B.
        \u0410 \u0442\u0435, \u0447\u0435\u0439 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440
        \u043E\u043D \u0443\u0441\u043B\u044B\u0448\u0430\u043B, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0442
        \u0437\u0430\u0441\u0435\u0434\u0430\u0442\u044C \u0437\u0430 \u0437\u0430\u043A\u0440\u044B\u0442\u044B\u043C\u0438
        \u0434\u0432\u0435\u0440\u044F\u043C\u0438."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 3
    - text: "\u041D\u043E \u0443 \u0430\u043D\u043E\u043D\u0438\u043C\u043A\u0438
        \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043C\u043B\u0430\u0434\u0448\u0438\u0439
        \u0431\u0440\u0430\u0442 \u2014 \u0442\u0435\u043E\u0440\u0438\u044F \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u0435\u0435.
        \u0414\u0440\u0443\u0433\u043E\u0439 \u0430\u043D\u043E\u043D\u0438\u043C,
        \u0442\u043E\u0436\u0435 \u0438\u0437 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E
        \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0430, \u0442\u043E\u0436\u0435
        \u0431\u0435\u0437 \u0438\u043C\u0435\u043D\u0438 \u0438 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438,
        \u0441\u043E\u043E\u0431\u0449\u0430\u0435\u0442, \u0447\u0442\u043E \u043F\u043E\u0434\u0441\u043B\u0443\u0448\u0430\u043B
        \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440 \u0437\u0430 \u043D\u0435\u043F\u043B\u043E\u0442\u043D\u043E
        \u043F\u0440\u0438\u043A\u0440\u044B\u0442\u043E\u0439 \u0434\u0432\u0435\u0440\u044C\u044E.
        \u0412 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0435 \u2014 \u043D\u0435\u043A\u0438\u0439
        \u0424\u0435\u0434\u044C\u043A\u043E, \u0434\u0432\u043E\u0435 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
        \u043F\u0440\u0438\u0435\u0437\u0436\u0438\u0445 \u0438 \u0444\u0440\u0430\u0437\u0430
        \u043F\u0440\u043E \u0434\u0432\u0435\u0441\u0442\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
        \u0434\u043B\u044F \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0440\u043E\u0438\u0442\u0441\u044F
        \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u044B\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441.
        \u041E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u2014 \xAB\u0432\u043E\u043F\u0440\u043E\u0441
        \u0432\u0440\u0435\u043C\u0435\u043D\u0438\xBB. \u0410\u0432\u0442\u043E\u0440
        \u043D\u0435 \u0441\u043F\u0438\u0442. \u0410\u0432\u0442\u043E\u0440 \u0431\u043E\u0438\u0442\u0441\u044F.
        \u0410\u0432\u0442\u043E\u0440 \u043F\u0440\u043E\u0441\u0438\u0442 \u0437\u0430\u0434\u0430\u0442\u044C
        \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u0432 \u044D\u0444\u0438\u0440\u0435
        \u2014 \u043D\u043E \u0441\u0430\u043C \u043F\u043E\u0447\u0435\u043C\u0443-\u0442\u043E
        \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u043D\u0430\u0437\u0432\u0430\u0442\u044C
        \u043D\u0438 \u044D\u0442\u0430\u0436, \u043D\u0438 \u0434\u0430\u0442\u0443,
        \u043D\u0438 \u0445\u043E\u0442\u044F \u0431\u044B \u0432\u0440\u0435\u043C\u044F
        \u0441\u0443\u0442\u043E\u043A, \u043A\u043E\u0433\u0434\u0430 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0441\u044F
        \u044D\u0442\u043E\u0442 \u0441\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u044B\u0439
        \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440."
      factionAPoints: 0
      factionBPoints: 1
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 4
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u0422\u0435\u043F\u0435\u0440\u044C \u2014 \u0432\u0442\u043E\u0440\u043E\u0435
        \u043F\u0438\u0441\u044C\u043C\u043E, \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0432\u0448\u0435\u0435
        \u0432 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u044E \u043E\u0442 \u0434\u0440\u0443\u0433\u043E\u0433\u043E
        \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0433\u043E \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430
        \u0438\u0437 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E
        \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0430. \u0410\u0432\u0442\u043E\u0440
        \u0441\u043E\u043E\u0431\u0449\u0430\u0435\u0442, \u0447\u0442\u043E \u0442\u0440\u0438
        \u043D\u0435\u0434\u0435\u043B\u0438 \u043D\u0430\u0437\u0430\u0434 \u043F\u043E\u0434\u0441\u043B\u0443\u0448\u0430\u043B
        \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440 \u0432 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435
        \u0424\u0435\u0434\u044C\u043A\u043E \u2014 \u0438\u043C\u044F, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
        \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0437\u043D\u0430\u044E\u0442
        \u0442\u0435, \u043A\u043E\u043C\u0443 \u043B\u0443\u0447\u0448\u0435 \u0431\u044B
        \u043D\u0435 \u0437\u043D\u0430\u0442\u044C. \u0424\u0435\u0434\u044C\u043A\u043E
        \u0431\u0435\u0441\u0435\u0434\u043E\u0432\u0430\u043B \u0441 \u0434\u0432\u0443\u043C\u044F
        \u043B\u044E\u0434\u044C\u043C\u0438, \u043F\u0440\u0438\u0435\u0445\u0430\u0432\u0448\u0438\u043C\u0438
        \u043D\u0435 \u0438\u0437 \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434\u0430.
        \u0410\u0432\u0442\u043E\u0440 \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043B
        \u043D\u0435 \u0432\u0441\u0451, \u043D\u043E \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043B
        \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E. \u0421\u0442\u0440\u043E\u0438\u0442\u0441\u044F
        \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u044B\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441.
        \u041D\u0435 \u043F\u043E\u0433\u0440\u0435\u0431, \u043D\u0435 \u0443\u043A\u0440\u044B\u0442\u0438\u0435
        \u2014 \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u044B\u0439
        \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441 \u0441 \u044F\u0440\u0443\u0441\u0430\u043C\u0438
        \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u0444\u0438\u043B\u044C\u0442\u0440\u0430\u0446\u0438\u0438.
        \u0418 \u0444\u0440\u0430\u0437\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
        \u0430\u0432\u0442\u043E\u0440 \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B
        \u0434\u043E\u0441\u043B\u043E\u0432\u043D\u043E: \xAB\u041D\u0430 \u043F\u043E\u043B\u0442\u043E\u0440\u044B
        \u0442\u044B\u0441\u044F\u0447\u0438 \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0442\u044C
        \u043D\u0435 \u043D\u0443\u0436\u043D\u043E. \u0414\u0432\u0435\u0441\u0442\u0438
        \u2014 \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C. \u041E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435
        \u2014 \u0432\u043E\u043F\u0440\u043E\u0441 \u0432\u0440\u0435\u043C\u0435\u043D\u0438.\xBB
        \u0414\u0432\u0435\u0441\u0442\u0438 \u0438\u0437 \u0434\u0432\u0443\u0445
        \u0442\u044B\u0441\u044F\u0447. \u0414\u0435\u0441\u044F\u0442\u044C \u043F\u0440\u043E\u0446\u0435\u043D\u0442\u043E\u0432.
        \u0410\u0432\u0442\u043E\u0440 \u0437\u0430\u0434\u0430\u0451\u0442 \u0432\u043E\u043F\u0440\u043E\u0441\u044B,
        \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0443 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u0438
        \u043D\u0435\u0442 \u043E\u0442\u0432\u0435\u0442\u043E\u0432: \u0434\u043B\u044F
        \u043A\u043E\u0433\u043E \u0431\u0443\u043D\u043A\u0435\u0440? \u041F\u043E
        \u043A\u0430\u043A\u043E\u043C\u0443 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0443
        \u043E\u0442\u0431\u0435\u0440\u0443\u0442? \u041A\u0442\u043E \u0440\u0435\u0448\u0430\u0435\u0442,
        \u043A\u0430\u043A\u0438\u0435 \u0434\u0432\u0435\u0441\u0442\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
        \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u044E\u0442 \u0436\u0438\u0442\u044C?
        \u0418 \u0435\u0449\u0451: \u043A\u0443\u0434\u0430 \u043A\u0430\u0436\u0434\u0443\u044E
        \u043D\u043E\u0447\u044C, \u0431\u0435\u0437 \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0439,
        \u0443\u0445\u043E\u0434\u044F\u0442 \u0433\u0440\u0443\u0437\u043E\u0432\u0438\u043A\u0438
        \u0441 \u043B\u044E\u0434\u044C\u043C\u0438 \u0438 \u0442\u0435\u0445\u043D\u0438\u043A\u043E\u0439
        \u043D\u0430 \u0421\u0435\u0432\u0435\u0440\u043D\u044B\u0439 \u0432\u044B\u0435\u0437\u0434?
        \u041A\u0443\u0434\u0430 \u0438\u0441\u0447\u0435\u0437\u0430\u044E\u0442
        \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
        \u043D\u0435 \u0434\u043E\u0435\u0437\u0436\u0430\u044E\u0442 \u0434\u043E
        \u0433\u043E\u0440\u043E\u0434\u0430?"
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 5
    - text: "\u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0435\u0442
        \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434.
        \u0420\u0435\u0441\u0443\u0440\u0441\u044B \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u044B,
        \u043C\u0435\u0442\u0435\u043B\u044C \u0443\u0441\u0438\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F,
        \u043D\u0435\u0440\u0432\u044B \u0441\u0434\u0430\u044E\u0442. \u0412 \u0442\u0430\u043A\u0438\u0445
        \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 \u043A\u043E\u043D\u0441\u043F\u0438\u0440\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
        \u0442\u0435\u043E\u0440\u0438\u0438 \u0440\u0430\u0441\u0442\u0443\u0442
        \u0431\u044B\u0441\u0442\u0440\u0435\u0435, \u0447\u0435\u043C \u0441\u0443\u0433\u0440\u043E\u0431\u044B,
        \u2014 \u0438 \u0432\u0440\u0435\u0434\u044F\u0442 \u043D\u0435 \u043C\u0435\u043D\u044C\u0448\u0435.
        \u041A\u0430\u0436\u0434\u044B\u0439 \u0441\u043B\u0443\u0445, \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u0430\u043D\u043D\u044B\u0439
        \u043A\u0430\u043A \u0444\u0430\u043A\u0442, \u043A\u0430\u0436\u0434\u0430\u044F
        \u0430\u043D\u043E\u043D\u0438\u043C\u043A\u0430, \u0437\u0430\u0447\u0438\u0442\u0430\u043D\u043D\u0430\u044F
        \u043A\u0430\u043A \u0440\u0430\u0437\u043E\u0431\u043B\u0430\u0447\u0435\u043D\u0438\u0435,
        \u043F\u043E\u0434\u0440\u044B\u0432\u0430\u0435\u0442 \u0442\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E\u0435,
        \u0447\u0442\u043E \u0435\u0449\u0451 \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
        \u0433\u043E\u0440\u043E\u0434 \u043E\u0442 \u0445\u0430\u043E\u0441\u0430
        \u2014 \u0434\u043E\u0432\u0435\u0440\u0438\u0435. \u041D\u0435 \u043A \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
        \u2014 \u0434\u0440\u0443\u0433 \u043A \u0434\u0440\u0443\u0433\u0443. \u041C\u043E\u0436\u043D\u043E
        \u0431\u043E\u044F\u0442\u044C\u0441\u044F \u0431\u0443\u043D\u043A\u0435\u0440\u0430,
        \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0438\u043A\u0442\u043E
        \u043D\u0435 \u0432\u0438\u0434\u0435\u043B. \u0410 \u043C\u043E\u0436\u043D\u043E
        \u0432\u044B\u0439\u0442\u0438 \u043D\u0430 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
        \u0440\u0430\u0431\u043E\u0442\u044B, \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C\u0441\u044F
        \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u0446\u0435\u043C,
        \u043F\u043E\u043C\u043E\u0447\u044C \u0441\u043E\u0441\u0435\u0434\u0443
        \u0437\u0430\u043A\u043E\u043B\u043E\u0442\u0438\u0442\u044C \u043E\u043A\u043D\u043E.
        \u0417\u0430\u0433\u043E\u0432\u043E\u0440\u044B \u043A\u043E\u043D\u0447\u0430\u044E\u0442\u0441\u044F,
        \u043A\u043E\u0433\u0434\u0430 \u043B\u044E\u0434\u044F\u043C \u0435\u0441\u0442\u044C
        \u0447\u0435\u043C \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F. \u0410
        \u043F\u043E\u043A\u0430 \u0441\u0430\u043C\u043E\u0435 \u0441\u0442\u0440\u0430\u0448\u043D\u043E\u0435
        \u043E\u0440\u0443\u0436\u0438\u0435 \u0432 \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434\u0435
        \u2014 \u043D\u0435 \u043C\u0435\u0442\u0435\u043B\u044C \u0438 \u043D\u0435
        \u0424\u0435\u0434\u044C\u043A\u043E. \u042D\u0442\u043E \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0435
        \u043F\u0438\u0441\u044C\u043C\u043E, \u0434\u043E\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0435
        \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0431\u0435\u0441\u0441\u043E\u043D\u043D\u043E\u0439
        \u043D\u043E\u0447\u044C\u044E."
      factionAPoints: 0
      factionBPoints: 1
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 6
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u0410\u0432\u0442\u043E\u0440 \u043F\u0438\u0441\u044C\u043C\u0430
        \u043D\u0435 \u0441\u043F\u0438\u0442 \u0441 \u0442\u043E\u0433\u043E \u0434\u043D\u044F.
        \u041E\u043D \u043D\u0435 \u0437\u043D\u0430\u0435\u0442, \u0432\u0445\u043E\u0434\u0438\u0442
        \u043B\u0438 \u0432 \u0447\u0438\u0441\u043B\u043E \u0434\u0432\u0443\u0445\u0441\u043E\u0442.
        \u0421\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E \u2014
        \u043D\u0435\u0442. \u0421\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E,
        \u043D\u0438\u043A\u0442\u043E \u0438\u0437 \u0442\u0435\u0445, \u043A\u0442\u043E
        \u0441\u043B\u0443\u0448\u0430\u0435\u0442 \u044D\u0442\u043E \u0440\u0430\u0434\u0438\u043E,
        \u043D\u0435 \u0432\u0445\u043E\u0434\u0438\u0442. \u041F\u043E\u0442\u043E\u043C\u0443
        \u0447\u0442\u043E \u0442\u0435, \u043A\u0442\u043E \u0432\u0445\u043E\u0434\u0438\u0442,
        \u0440\u0430\u0434\u0438\u043E \u043D\u0435 \u0441\u043B\u0443\u0448\u0430\u044E\u0442
        \u2014 \u043E\u043D\u0438 \u0443\u0436\u0435 \u0437\u043D\u0430\u044E\u0442
        \u0432\u0441\u0451, \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E. \u041F\u0435\u0440\u0435\u0445\u0432\u0430\u0447\u0435\u043D\u043D\u044B\u0439
        \u0441\u0438\u0433\u043D\u0430\u043B \u0415\u0440\u0448\u043E\u0432\u0430,
        \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0435 \u043F\u0438\u0441\u044C\u043C\u043E
        \u0438\u0437 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u0438,
        \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440 \u0432 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435
        \u0424\u0435\u0434\u044C\u043A\u043E \u2014 \u0442\u0440\u0438 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430,
        \u043D\u0435 \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445 \u0434\u0440\u0443\u0433
        \u0441 \u0434\u0440\u0443\u0433\u043E\u043C, \u0440\u0438\u0441\u0443\u044E\u0442
        \u043E\u0434\u043D\u0443 \u0438 \u0442\u0443 \u0436\u0435 \u043A\u0430\u0440\u0442\u0438\u043D\u0443.
        \u041F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
        \u0437\u043D\u0430\u0435\u0442, \u0447\u0442\u043E \u0433\u043E\u0440\u043E\u0434
        \u043E\u0431\u0440\u0435\u0447\u0451\u043D. \u041F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
        \u0441\u0442\u0440\u043E\u0438\u0442 \u0432\u044B\u0445\u043E\u0434 \u2014
        \u043D\u043E \u043D\u0435 \u0434\u043B\u044F \u0433\u043E\u0440\u043E\u0434\u0430.
        \u0414\u043B\u044F \u0441\u0435\u0431\u044F. \u0414\u0432\u0435\u0441\u0442\u0438
        \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0443\u0439\u0434\u0443\u0442
        \u043F\u043E\u0434 \u0437\u0435\u043C\u043B\u044E, \u0432 \u0442\u0435\u043F\u043B\u043E,
        \u0441 \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440\u0430\u043C\u0438
        \u0438 \u0437\u0430\u043F\u0430\u0441\u0430\u043C\u0438. \u041E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435
        \u0442\u044B\u0441\u044F\u0447\u0430 \u0432\u043E\u0441\u0435\u043C\u044C\u0441\u043E\u0442
        \u043E\u0441\u0442\u0430\u043D\u0443\u0442\u0441\u044F \u043D\u0430\u0432\u0435\u0440\u0445\u0443.
        \u041F\u043E\u0434 \u043C\u0435\u0442\u0435\u043B\u044C\u044E. \u041F\u043E\u0434
        \u043A\u0440\u0443\u0433\u043B\u043E\u0441\u0443\u0442\u043E\u0447\u043D\u044B\u043C
        \u043A\u043E\u043C\u0435\u043D\u0434\u0430\u043D\u0442\u0441\u043A\u0438\u043C
        \u0447\u0430\u0441\u043E\u043C. \u0421 \u0442\u0430\u044E\u0449\u0438\u043C\u0438
        \u043F\u0430\u0439\u043A\u0430\u043C\u0438 \u0438 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C\u0438,
