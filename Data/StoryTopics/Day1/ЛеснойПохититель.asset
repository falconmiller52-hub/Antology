    - text: "\u0412\u043E\u0440\u043E\u0431\u044C\u0451\u0432 \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u043B
        \u043D\u0430\u043A\u0430\u0437\u0430\u043D\u0438\u044F \u2014 \u0432 \u044D\u0442\u043E\u043C
        \u043D\u0435\u0442 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0439. \u041F\u044F\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u044C
        \u0434\u0435\u0442\u0435\u0439. \u041F\u044F\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u044C
        \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u043D\u044B\u0445 \u0441\u0435\u043C\u0435\u0439.
        \u041D\u043E \u0441\u0443\u0434 \u0437\u0430 \u043E\u0434\u0438\u043D \u0434\u0435\u043D\u044C
        \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u0430\u0432\u043E\u0441\u0443\u0434\u0438\u0435.
        \u042D\u0442\u043E \u0443\u0442\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u044F
        \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B. \u0417\u0430\u0449\u0438\u0442\u0435
        \u043D\u0435 \u0434\u0430\u043B\u0438 \u043F\u043E\u0434\u0430\u0442\u044C
        \u0430\u043F\u0435\u043B\u043B\u044F\u0446\u0438\u044E. \u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B
        \u0434\u0435\u043B\u0430 \u043D\u0435 \u0431\u044B\u043B\u0438 \u043E\u0433\u043B\u0430\u0448\u0435\u043D\u044B
        \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E. \u041C\u0430\u0442\u0435\u0440\u0438
        \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043D\u0435 \u0437\u043D\u0430\u044E\u0442,
        \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E
        \u0441 \u0438\u0445 \u0434\u0435\u0442\u044C\u043C\u0438 \u2014 \u043F\u043E\u0442\u043E\u043C\u0443
        \u0447\u0442\u043E \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0433\u043E
        \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
        \u043D\u0435 \u0431\u044B\u043B\u043E. \u0411\u044B\u043B \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440,
        \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0439 \u0440\u0430\u043D\u044C\u0448\u0435,
        \u0447\u0435\u043C \u0437\u0430\u0447\u0438\u0442\u0430\u043D. \u0421\u0435\u0433\u043E\u0434\u043D\u044F
        \u2014 \u043C\u0430\u043D\u044C\u044F\u043A. \u0423\u0434\u043E\u0431\u043D\u044B\u0439,
        \u0431\u0435\u0441\u0441\u043F\u043E\u0440\u043D\u044B\u0439, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
        \u043D\u0435 \u0436\u0430\u043B\u043A\u043E. \u041D\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C
        \u043E\u0431\u043A\u0430\u0442\u0430\u043D. \u0418 \u0437\u0430\u0432\u0442\u0440\u0430
        \u043D\u0430 \u044D\u0442\u043E\u043C \u0436\u0435 \u0441\u0442\u0443\u043B\u0435
        \u043C\u043E\u0436\u0435\u0442 \u043E\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F
        \u043A\u0442\u043E \u0443\u0433\u043E\u0434\u043D\u043E \u2014 \u0441 \u0442\u0435\u043C
        \u0436\u0435 \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u043E\u043C
        \u0438 \u0441 \u0442\u043E\u0439 \u0436\u0435 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E.
        \u0412\u043E\u043F\u0440\u043E\u0441 \u043D\u0435 \u0432 \u0442\u043E\u043C,
        \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u043B \u043B\u0438 \u0412\u043E\u0440\u043E\u0431\u044C\u0451\u0432
        \u0441\u043C\u0435\u0440\u0442\u0438. \u0412\u043E\u043F\u0440\u043E\u0441
        \u0432 \u0442\u043E\u043C, \u043A\u0442\u043E \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439."
