  m_Name: "\u041B\u0435\u0441\u043D\u043E\u0439\u041F\u043E\u0445\u0438\u0442\u0438\u0442\u0435\u043B\u044C"
  m_EditorClassIdentifier: Assembly-CSharp::StoryTopic
  topicTitle: "\u041F\u043E\u043B\u0438\u0446\u0438\u044F"
  topicDescription: ...
  blocks:
  - blockLabel: 
    phraseOptions:
    - text: "\u0422\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0430\u043F\u0440\u0435\u043B\u044F
        \u0432\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0441\u0438\u043B\u0443
        \u043F\u0440\u0438\u043A\u0430\u0437 \u043E\u0431 \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u0438
        \u0440\u0430\u0431\u043E\u0447\u0438\u0445 \u0447\u0430\u0441\u043E\u0432
        \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432 \u043F\u0440\u0430\u0432\u043E\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
        \u043E\u0440\u0433\u0430\u043D\u043E\u0432. \u0420\u0430\u0431\u043E\u0447\u0435\u0435
        \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \u043F\u043E\u043B\u0438\u0446\u0438\u0438
        \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u043E, \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
        \u043E\u0445\u0440\u0430\u043D\u043D\u044B\u0445 \u043F\u0443\u043D\u043A\u0442\u043E\u0432
        \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u043E.
        \u041C\u0435\u0440\u044B \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u044B
        \u043D\u0430 \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
        \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u044B\u0445 \u0441\u043B\u0443\u0447\u0430\u0435\u0432
        \u0438 \u043C\u0430\u0441\u0441\u043E\u0432\u044B\u0445 \u043F\u043E\u0442\u0430\u0441\u043E\u0432\u043E\u043A,
        \u0443\u0447\u0430\u0441\u0442\u0438\u0432\u0448\u0438\u0445\u0441\u044F
        \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u043D\u0435\u0434\u0435\u043B\u0438."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 1
    - text: "\u0422\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0430\u043F\u0440\u0435\u043B\u044F
        \u0432\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0441\u0438\u043B\u0443
        \u043F\u0440\u0438\u043A\u0430\u0437 \u043E\u0431 \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u0438
        \u0440\u0430\u0431\u043E\u0447\u0438\u0445 \u0447\u0430\u0441\u043E\u0432
        \u043F\u043E\u043B\u0438\u0446\u0438\u0438. \u041E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F
        \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430
        \u2014 \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
        \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u044B\u0445 \u0441\u043B\u0443\u0447\u0430\u0435\u0432
        \u0438 \u043C\u0430\u0441\u0441\u043E\u0432\u044B\u0445 \u043F\u043E\u0442\u0430\u0441\u043E\u0432\u043E\u043A.
        \u0427\u0438\u0441\u043B\u043E \u043E\u0445\u0440\u0430\u043D\u043D\u044B\u0445
        \u043F\u0443\u043D\u043A\u0442\u043E\u0432 \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u043E.
        \u041D\u0430 \u0431\u0443\u043C\u0430\u0433\u0435 \u2014 \u0437\u0430\u0431\u043E\u0442\u0430
        \u043E \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438.
        \u041D\u0430 \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0435 \u2014 \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F,
        \u043E \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0432 \u043F\u0440\u0438\u043A\u0430\u0437\u0435
        \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0441\u043A\u0430\u0437\u0430\u043D\u043E."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 2
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u0427\u0435\u0442\u0432\u0451\u0440\u0442\u043E\u0433\u043E \u0430\u043F\u0440\u0435\u043B\u044F
        \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E\u0441\u044C \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
        \u0441\u0443\u0434\u0435\u0431\u043D\u043E\u0435 \u0441\u043B\u0443\u0448\u0430\u043D\u0438\u0435
        \u043F\u043E \u0434\u0435\u043B\u0443 \u0412\u0435\u043B\u0435\u043C\u0438\u0440\u0430
        \u0412\u043E\u0440\u043E\u0431\u044C\u0451\u0432\u0430, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
        \u043A\u0430\u043A \xAB\u041B\u0435\u0441\u043D\u0438\u0447\u0438\u0439\xBB.
        \u041F\u043E\u0445\u0438\u0442\u0438\u0442\u0435\u043B\u044C, \u0436\u0435\u0440\u0442\u0432\u0430\u043C\u0438
        \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0441\u0442\u0430\u043B\u0438
        \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 \u043F\u044F\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0438
        \u0434\u0435\u0442\u0435\u0439 \u0438\u0437 \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0433\u043E
        \u0434\u0435\u0442\u0441\u043A\u043E\u0433\u043E \u0434\u043E\u043C\u0430
        \u0438 \u0441\u0435\u043C\u0435\u0439 \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434\u0430,
        \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0451\u043D \u043A \u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0439
        \u043A\u0430\u0437\u043D\u0438. \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
        \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B\u0441\u044F
        \u0432\u0430\u0440\u0438\u0430\u043D\u0442 \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
        \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F, \u043E\u0434\u043D\u0430\u043A\u043E
        \u0441\u0443\u0434 \u043F\u0440\u0438\u043D\u044F\u043B \u0440\u0435\u0448\u0435\u043D\u0438\u0435,
        \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043C\u043D\u043E\u0433\u0438\u0435
        \u0436\u0438\u0442\u0435\u043B\u0438 \u0433\u043E\u0440\u043E\u0434\u0430
        \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E
        \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u044B\u043C."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 3
    - text: "\u0427\u0435\u0442\u0432\u0451\u0440\u0442\u043E\u0433\u043E \u0430\u043F\u0440\u0435\u043B\u044F
        \u0412\u0435\u043B\u0435\u043C\u0438\u0440 \u0412\u043E\u0440\u043E\u0431\u044C\u0451\u0432,
        \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0430\u043A
        \xAB\u041B\u0435\u0441\u043D\u0438\u0447\u0438\u0439\xBB, \u0431\u044B\u043B
        \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0451\u043D \u043A \u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0439
        \u043A\u0430\u0437\u043D\u0438 \u043F\u043E \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044E
        \u0432 \u043F\u043E\u0445\u0438\u0449\u0435\u043D\u0438\u0438 \u043D\u0435
        \u043C\u0435\u043D\u0435\u0435 \u043F\u044F\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0438
        \u0434\u0435\u0442\u0435\u0439. \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0439
        \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440 \u043F\u0440\u0435\u0434\u0443\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B
        \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435,
        \u043E\u0434\u043D\u0430\u043A\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440\u0435\u043D
        \u2014 \u0438 \u0443\u0436\u0435\u0441\u0442\u043E\u0447\u0451\u043D \u0434\u043E
        \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0435\u0440\u044B. \u0421\u0443\u0434,
        \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440 \u0438 \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
        \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440 \u0443\u043B\u043E\u0436\u0438\u043B\u0438\u0441\u044C
        \u0432 \u043E\u0434\u0438\u043D \u0434\u0435\u043D\u044C."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 3
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u0417\u0430 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
        \u0445\u0440\u043E\u043D\u0438\u043A\u043E\u0439 \u2014 \u0436\u0438\u0432\u0430\u044F
        \u0431\u043E\u043B\u044C. \u0412 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u044E
        \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u043E \u043F\u0438\u0441\u044C\u043C\u043E
        \u043E\u0442 \u043C\u0430\u0442\u0435\u0440\u0438 \u043E\u0434\u043D\u043E\u0439
        \u0438\u0437 \u043F\u043E\u0445\u0438\u0449\u0435\u043D\u043D\u044B\u0445
        \u0434\u0435\u0432\u043E\u0447\u0435\u043A. \u0415\u0451 \u0434\u043E\u0447\u044C
        \u041A\u0430\u0442\u044E \u2014 \u043E\u0434\u0438\u043D\u043D\u0430\u0434\u0446\u0430\u0442\u044C
        \u043B\u0435\u0442, \u0441\u0432\u0435\u0442\u043B\u044B\u0435 \u0432\u043E\u043B\u043E\u0441\u044B,
        \u0449\u0435\u0440\u0431\u0438\u043D\u043A\u0430 \u043C\u0435\u0436\u0434\u0443
        \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u043C\u0438 \u0437\u0443\u0431\u0430\u043C\u0438
        \u2014 \u0437\u0430\u0431\u0440\u0430\u043B\u0438 \u0438\u0437 \u0434\u043E\u043C\u0430.
        \u041C\u0430\u0442\u044C \u0440\u0430\u0441\u043A\u043B\u0435\u0438\u0432\u0430\u043B\u0430
        \u0441\u0430\u043C\u043E\u0434\u0435\u043B\u044C\u043D\u044B\u0435 \u043E\u0431\u044A\u044F\u0432\u043B\u0435\u043D\u0438\u044F
        \u043F\u043E \u0432\u0441\u0435\u043C\u0443 \u0433\u043E\u0440\u043E\u0434\u0443.
        \u041F\u0438\u0441\u0430\u043B\u0430 \u0432 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u044E
        \u2014 \u0447\u0435\u0442\u044B\u0440\u0435\u0436\u0434\u044B. \u041F\u0440\u043E\u0441\u0438\u043B\u0430
        \u043D\u0435 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438,
        \u043D\u0435 \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0445
        \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043E\u043A
        \u2014 \u043F\u0440\u043E\u0441\u0438\u043B\u0430 \u043F\u0440\u0430\u0432\u0434\u044B
        \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u0436\u0438\u043B
        \u0435\u0451 \u0440\u0435\u0431\u0451\u043D\u043E\u043A. \u042D\u0442\u043E
        \u043F\u0438\u0441\u044C\u043C\u043E \u2014 \u0433\u043E\u043B\u043E\u0441
        \u0442\u0435\u0445, \u0434\u043B\u044F \u043A\u043E\u0433\u043E \u0441\u043B\u043E\u0432\u043E
        \xAB\u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\xBB \u043D\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u044F,
        \u0430 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
        \u0441\u043F\u043E\u0441\u043E\u0431 \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
        \u0442\u043E\u0447\u043A\u0443 \u0432 \u043A\u043E\u0448\u043C\u0430\u0440\u0435,
        \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u043B\u0438\u043B\u0441\u044F
        \u043C\u0435\u0441\u044F\u0446\u044B. \u041C\u0430\u0442\u044C \u0434\u0432\u043E\u0438\u0445
        \u0434\u0440\u0443\u0433\u0438\u0445 \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u0432\u0448\u0438\u0445
        \u0434\u0435\u0442\u0435\u0439 \u043D\u0430 \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0438
        \u0441\u0443\u0434\u0430 \u0432\u044B\u0441\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
        \u0431\u0435\u0437 \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u0438:
        \u0442\u0430\u043A\u0438\u0445 \u043D\u0443\u0436\u043D\u043E \u0438\u0441\u0442\u0440\u0435\u0431\u043B\u044F\u0442\u044C
        \u0441\u0440\u0430\u0437\u0443, \u0441\u0440\u0435\u0437\u0430\u044F \u0433\u043E\u043B\u043E\u0432\u0443.
        \u042D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E
        \u2014 \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E. \u041D\u043E
        \u0437\u0430 \u044D\u0442\u0438\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438
        \u2014 \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u043E\u0435
        \u0433\u043E\u0440\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
        \u043D\u0435 \u043D\u0443\u0436\u043D\u044B \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0438."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: -1
    - text: "\u041E\u0434\u0438\u043D \u0434\u0435\u043D\u044C. \u041F\u043E \u0434\u0430\u043D\u043D\u044B\u043C,
        \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u043C \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u0435\u0439
        \u0438\u0437 \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0433\u043E
        \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430, \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
        \u0441\u0443\u0434\u0435\u0431\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430
        \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B\u0430\u0441\u044C \u043D\u0435
        \u0442\u044F\u0436\u0435\u0441\u0442\u044C\u044E \u0443\u043B\u0438\u043A,
        \u0430 \u0442\u0435\u043C, \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u043E
        \u0437\u0430 \u0441\u0442\u0435\u043D\u0430\u043C\u0438 \u0441\u0443\u0434\u0430.
        \u0423 \u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0442\u0443\u0440\u044B
        \u0441\u043E\u0431\u0440\u0430\u043B\u0430\u0441\u044C \u0442\u043E\u043B\u043F\u0430
        \u2014 \u0434\u0432\u0435\u0441\u0442\u0438, \u0442\u0440\u0438\u0441\u0442\u0430
        \u0447\u0435\u043B\u043E\u0432\u0435\u043A. \u041B\u044E\u0434\u0438 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0438
        \u0432\u044B\u0434\u0430\u0442\u044C \u0412\u043E\u0440\u043E\u0431\u044C\u0451\u0432\u0430.
        \u041A\u0442\u043E-\u0442\u043E \u043A\u0440\u0438\u0447\u0430\u043B \u2014
        \u043F\u043E\u0432\u0435\u0441\u0438\u0442\u044C \u043D\u0430 \u043F\u043B\u043E\u0449\u0430\u0434\u0438.
        \u041A\u0442\u043E-\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B
        \u0445\u0443\u0434\u0448\u0435\u0435. \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C
        \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430, \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
        \u0438\u0441\u043F\u0443\u0433\u0430\u043B\u043E\u0441\u044C \u2014 \u043D\u0435
        \u043E\u0431\u0432\u0438\u043D\u044F\u0435\u043C\u043E\u0433\u043E, \u0430
        \u0442\u043E\u043B\u043F\u044B. \u0415\u0441\u043B\u0438 \u0431\u044B \u043B\u044E\u0434\u0438
        \u0434\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u0434\u043E \u043A\u0430\u043C\u0435\u0440\u044B,
        \u043E\u043D\u0438 \u0431\u044B \u0440\u0430\u0441\u0442\u0435\u0440\u0437\u0430\u043B\u0438
        \u0412\u043E\u0440\u043E\u0431\u044C\u0451\u0432\u0430. \u0410 \u043F\u043E\u0442\u043E\u043C
        \u2014 \u043A\u043E\u043D\u0432\u043E\u0439. \u041F\u043E\u0442\u043E\u043C
        \u2014 \u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0442\u0443\u0440\u0443.
        \u041F\u043E\u0442\u043E\u043C \u2014 \u043A\u043E\u0433\u043E \u043F\u043E\u0439\u043C\u0430\u044E\u0442.
        \u0412\u043B\u0430\u0441\u0442\u044F\u043C \u043D\u0443\u0436\u0435\u043D
        \u0431\u044B\u043B \u0431\u044B\u0441\u0442\u0440\u044B\u0439 \u0441\u043F\u0435\u043A\u0442\u0430\u043A\u043B\u044C:
        \u0441\u0443\u0434, \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440, \u043A\u0430\u0437\u043D\u044C,
        \u043D\u0430\u0440\u043E\u0434 \u0440\u0430\u0441\u0445\u043E\u0434\u0438\u0442\u0441\u044F.
        \u041E\u0434\u043D\u0438\u043C \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C
        \u2014 \u0438 \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u0438\u043A\u0430
        \u0443\u0441\u0442\u0440\u0430\u043D\u0438\u043B\u0438, \u0438 \u0431\u0443\u043D\u0442
        \u043F\u043E\u0433\u0430\u0441\u0438\u043B\u0438, \u0438 \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0438:
        \u043C\u044B \u0440\u0435\u0448\u0430\u0435\u043C, \u043A\u0442\u043E \u0436\u0438\u0432\u0451\u0442,
        \u0430 \u043A\u0442\u043E \u043D\u0435\u0442."
      factionAPoints: 0
      factionBPoints: 0
