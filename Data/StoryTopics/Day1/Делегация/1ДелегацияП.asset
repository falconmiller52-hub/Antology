  broadcastText: "\u0414\u043E\u0441\u0442\u0438\u0433\u043D\u0443\u0442\u043E \u0441\u043E\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u043E\u0431 \u043E\u0431\u043C\u0435\u043D\u0435 \u0443\u0433\u043B\u044F \u043D\u0430
    \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u044B, \u043F\u0435\u0440\u0432\u0430\u044F
    \u043F\u0430\u0440\u0442\u0438\u044F \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u0436\u0438\u0434\u0430\u0435\u0442\u0441\u044F \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    \u0434\u0432\u0443\u0445 \u043D\u0435\u0434\u0435\u043B\u044C. \u0413\u043B\u0430\u0432\u0430
    \u0434\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u0438 \u041A. \u0412. \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432
    \u043E\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u043E\u0432\u0430\u043B
    \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u044B \u043A\u0430\u043A
    \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u044B\u0435, \u043D\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0438\u0432\u043D\u044B\u0435."
