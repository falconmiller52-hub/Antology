  m_Name: "3\u0414\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u044F\u041F"
  m_EditorClassIdentifier: Assembly-CSharp::StoryNode
  label: "3\u043F"
  description: "\u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E
    \u043E\u0442\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u041E\u0437\u0451\u0440\u043D\u043E\u0435
    \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043E \u0431\u043B\u0438\u0436\u0435
    \u0432\u0441\u0435\u0433\u043E \u043A \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434\u0443,
    \u0447\u0442\u043E \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0435\u0442
    \u0431\u044B\u0441\u0442\u0440\u0443\u044E \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u043F\u043E\u0441\u0442\u0430\u0432\u043E\u043A \u0438 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0438\u0441\u043A \u0432\u043C\u0435\u0448\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043F\u043E\u0433\u043E\u0434\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u0439.
    \u041F\u0440\u0438 \u044D\u0442\u043E\u043C \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442 \u0441\u0432\u044F\u0437\u044C
    \u0438 \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0448\u0442\u0430\u0431\u0430\u043C\u0438
    \u2014 \u0418\u0436\u0435\u0432\u0441\u043A\u043E\u043C, \u041B\u0435\u0431\u0435\u0434\u0435\u0432\u0441\u043A\u043E\u043C,
    \u041A\u0430\u043C\u0435\u043D\u0441\u043A\u0438\u043C \u0438 \u0425\u041D\u0420"
