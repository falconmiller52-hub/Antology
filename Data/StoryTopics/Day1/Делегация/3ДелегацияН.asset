  m_EditorClassIdentifier: Assembly-CSharp::StoryNode
  label: "3\u043D"
  description: "\u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E
