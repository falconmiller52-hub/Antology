    \u0438 \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0448\u0442\u0430\u0431\u0430\u043C\u0438
    \u2014 \u0418\u0436\u0435\u0432\u0441\u043A\u043E\u043C, \u041B\u0435\u0431\u0435\u0434\u0435\u0432\u0441\u043A\u043E\u043C,
    \u041A\u0430\u043C\u0435\u043D\u0441\u043A\u0438\u043C \u0438 \u0425\u041D\u0420.
    \u041F\u0440\u0438 \u044D\u0442\u043E\u043C \u043F\u043E \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F\u043C
    \u0440\u0430\u0437\u0432\u0435\u0434\u043A\u0438 \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u043C
    \u0440\u0430\u0434\u0438\u0443\u0441\u0435 \u0432\u043E\u043A\u0440\u0443\u0433
    \u0433\u043E\u0440\u043E\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B\u043E \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u043E
    \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0433\u043E
