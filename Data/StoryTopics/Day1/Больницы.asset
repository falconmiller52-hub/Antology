    - text: "\u041B\u0430\u0437\u0430\u0440\u0435\u0442\u044B \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434\u0430
        \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u0438 \u0431\u044B\u0442\u044C
        \u043C\u0435\u0441\u0442\u043E\u043C, \u0433\u0434\u0435 \u043B\u0435\u0447\u0430\u0442.
        \u041E\u043D\u0438 \u0441\u0442\u0430\u043B\u0438 \u043C\u0435\u0441\u0442\u043E\u043C,
        \u043A\u0443\u0434\u0430 \u043D\u0435 \u043F\u043E\u043F\u0430\u0441\u0442\u044C.
        \u041E\u0447\u0435\u0440\u0435\u0434\u0438 \u043D\u0430 \u043C\u043E\u0440\u043E\u0437\u0435,
        \u043F\u0443\u0441\u0442\u044B\u0435 \u043F\u043E\u043B\u043A\u0438 \u0441
        \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u0430\u043C\u0438,
        \u0444\u0435\u043B\u044C\u0434\u0448\u0435\u0440\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
        \u043D\u0430\u0443\u0447\u0438\u043B\u0438\u0441\u044C \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
        \xAB\u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442\u0435 \u0447\u0435\u0440\u0435\u0437
        \u0442\u0440\u0438 \u0434\u043D\u044F\xBB \u043D\u0435 \u0433\u043B\u044F\u0434\u044F
        \u0432 \u0433\u043B\u0430\u0437\u0430. \u0413\u043E\u0440\u043E\u0434 \u0442\u0435\u0440\u044F\u0435\u0442
        \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0431\u043E\u043B\u044C\u043D\u044B\u0445
        \u2014 \u0433\u043E\u0440\u043E\u0434 \u0442\u0435\u0440\u044F\u0435\u0442
        \u0432\u0435\u0440\u0443 \u0432 \u0442\u043E, \u0447\u0442\u043E \u043A\u043E\u043C\u0443-\u0442\u043E
        \u0435\u0441\u0442\u044C \u0434\u0435\u043B\u043E."
