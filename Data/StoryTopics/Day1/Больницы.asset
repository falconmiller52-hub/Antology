  m_Script: {fileID: 11500000, guid: 1f8e96b1fbd882f4a946116fbd1af7b9, type: 3}
  m_Name: "\u0411\u043E\u043B\u044C\u043D\u0438\u0446\u044B"
  m_EditorClassIdentifier: Assembly-CSharp::StoryTopic
  topicTitle: "\u0411\u043E\u043B\u044C\u043D\u0438\u0446\u044B"
  topicDescription: ...
  blocks:
  - blockLabel: 
    phraseOptions:
    - text: "\u041D\u0435\u0445\u0432\u0430\u0442\u043A\u0430 \u043C\u0435\u0441\u0442
        \u0432 \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u0438\u0445 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0430\u0445
        \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F \u043E\u0434\u043D\u043E\u0439
        \u0438\u0437 \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u043E\u0441\u0442\u0440\u044B\u0445
        \u043F\u0440\u043E\u0431\u043B\u0435\u043C \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434\u0430.
        \u0427\u0438\u0441\u043B\u043E \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0439
        \u0440\u0430\u0441\u0442\u0451\u0442, \u043A\u043E\u0439\u043A\u0438 \u043F\u0435\u0440\u0435\u043F\u043E\u043B\u043D\u0435\u043D\u044B,
        \u0430 \u0441\u0440\u0435\u0434\u0438 \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044F
        \u0443\u0441\u0438\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F \u0442\u0440\u0435\u0432\u043E\u0436\u043D\u043E\u0441\u0442\u044C,
        \u043A\u043E\u0442\u043E\u0440\u0430\u044F, \u043F\u043E \u0434\u0430\u043D\u043D\u044B\u043C
        \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u0438,
        \u0443\u0436\u0435 \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u043A \u0443\u0447\u0430\u0441\u0442\u0438\u0432\u0448\u0438\u043C\u0441\u044F
        \u0441\u043B\u0443\u0447\u0430\u044F\u043C \u0432\u043E\u0440\u043E\u0432\u0441\u0442\u0432\u0430
        \u0432 \u0430\u043F\u0442\u0435\u043A\u0430\u0445 \u0438 \u043D\u0430 \u0440\u044B\u043D\u043A\u0430\u0445."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 1
    - text: "\u0413\u043E\u0440\u043E\u0434\u0441\u043A\u0438\u0435 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u044B
        \u043F\u0435\u0440\u0435\u043F\u043E\u043B\u043D\u0435\u043D\u044B. \u0427\u0438\u0441\u043B\u043E
        \u0436\u0430\u043B\u043E\u0431 \u043E\u0442 \u0436\u0438\u0442\u0435\u043B\u0435\u0439
        \u0440\u0430\u0441\u0442\u0451\u0442 \u0441 \u043A\u0430\u0436\u0434\u043E\u0439
        \u043D\u0435\u0434\u0435\u043B\u0435\u0439, \u0438 \u0440\u0435\u0447\u044C
        \u0434\u0430\u0432\u043D\u043E \u043D\u0435 \u043E \u043D\u0435\u0443\u0434\u043E\u0431\u0441\u0442\u0432\u0430\u0445
        \u2014 \u0440\u0435\u0447\u044C \u043E \u043B\u044E\u0434\u044F\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u043C
        \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0432 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0439
        \u043F\u043E\u043C\u043E\u0449\u0438. \u0411\u044B\u0432\u0448\u0438\u0439
        \u0447\u043B\u0435\u043D \u0441\u043E\u0432\u0435\u0442\u0430 \u0412\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
        \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
        \u043F\u043E \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
        \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0435 \u0410\u043D\u043D\u0430
        \u041C\u043E\u0440\u043E\u0437\u043E\u0432\u0430 \u043E\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u043E\u0432\u0430\u043B\u0430
        \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u044F\u0449\u0435\u0435
        \u0442\u0430\u043A: \u0433\u043E\u0440\u043E\u0434 \u043A\u0430\u0442\u0438\u0442\u0441\u044F
        \u0432 \u0434\u044B\u0440\u0443 \u0433\u043B\u0443\u0431\u0436\u0435, \u0447\u0435\u043C
        \u043A\u0442\u043E-\u043B\u0438\u0431\u043E \u043C\u043E\u0436\u0435\u0442
        \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 2
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u041E\u0434\u043D\u0430\u043A\u043E \u043D\u0430 \u0444\u043E\u043D\u0435
        \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445 \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0435\u0439
        \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B
        \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
        \u2014 \u0437\u0430\u0447\u0430\u0441\u0442\u0443\u044E \u0432 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445
        \u043F\u0440\u044F\u043C\u044B\u0445 \u0443\u0433\u0440\u043E\u0437. \u0420\u0435\u0434\u0430\u043A\u0446\u0438\u044F
        \u0440\u0430\u0441\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u0442 \u0437\u0430\u043F\u0438\u0441\u044C\u044E
        \u0440\u0430\u0434\u0438\u043E\u043F\u0435\u0440\u0435\u0445\u0432\u0430\u0442\u0430,
        \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
        \u043C\u0443\u0436\u0447\u0438\u043D\u0430 \u0443\u0433\u0440\u043E\u0436\u0430\u0435\u0442
        \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0440\u0430\u0441\u043F\u0440\u0430\u0432\u043E\u0439
        \u043E\u0434\u043D\u043E\u043C\u0443 \u0438\u0437 \u0445\u0438\u0440\u0443\u0440\u0433\u043E\u0432
        \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0430 \u0437\u0430 \u043E\u0442\u043A\u0430\u0437
        \u043F\u0440\u0438\u043D\u044F\u0442\u044C \u0435\u0433\u043E \u0436\u0435\u043D\u0443
        \u0431\u0435\u0437 \u043E\u0447\u0435\u0440\u0435\u0434\u0438. \u0412\u0440\u0430\u0447,
        \u043F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0443\u0433\u0440\u043E\u0436\u0430\u044E\u0449\u0435\u0433\u043E,
        \u043D\u0430\u0437\u0432\u0430\u043B \u0441\u043B\u0443\u0447\u0430\u0439
        \xAB\u043D\u0435 \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u043D\u044B\u043C\xBB
        \u2014 \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
        \u0442\u044F\u0436\u0451\u043B\u043E\u0435, \u043D\u043E \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u043D\u043E\u0435
        \u0432 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438, \u043A\u043E\u0433\u0434\u0430
        \u043D\u0430 \u043E\u0434\u043D\u043E\u0433\u043E \u043C\u0435\u0434\u0438\u043A\u0430
        \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u0434\u0435\u0441\u044F\u0442\u043A\u0438
        \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u043E\u0432 \u0432 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
        \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438. \u0421\u0438\u0441\u0442\u0435\u043C\u0430
        \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u043E\u0432 \u2014
        \u043D\u0435 \u0436\u0435\u0441\u0442\u043E\u043A\u043E\u0441\u0442\u044C,
        \u0430 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C:
        \u043A\u043E\u0433\u0434\u0430 \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432
        \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
        \u0434\u043B\u044F \u0432\u0441\u0435\u0445, \u043A\u0442\u043E-\u0442\u043E
        \u0434\u043E\u043B\u0436\u0435\u043D \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C
        \u0440\u0435\u0448\u0435\u043D\u0438\u044F, \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0435
        \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0442 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u0442\u044C."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 3
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u0415\u0449\u0451 \u0441\u0442\u0440\u0430\u0448\u043D\u0435\u0435
        \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
        \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
        \u043F\u043E \u0440\u0430\u0434\u0438\u043E\u043F\u0435\u0440\u0435\u0445\u0432\u0430\u0442\u0443.
        \u041C\u0430\u0442\u044C \u0434\u0432\u043E\u0438\u0445 \u0434\u0435\u0442\u0435\u0439
        \u2014 \u041D\u0430\u0441\u0442\u0438 \u0441\u0435\u043C\u0438 \u043B\u0435\u0442
        \u0438 \u0447\u0435\u0442\u044B\u0440\u0451\u0445\u043B\u0435\u0442\u043D\u0435\u0433\u043E
        \u0412\u0430\u043D\u0435\u0447\u043A\u0438 \u2014 \u043D\u0435\u0441\u043B\u0430
        \u0438\u0445 \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0443 \u043D\u0430
        \u0440\u0443\u043A\u0430\u0445. \u0427\u0435\u0442\u044B\u0440\u0435 \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u0430.
        \u0423 \u043E\u0431\u043E\u0438\u0445 \u0436\u0430\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
        \u043D\u0435 \u0441\u043F\u0430\u0434\u0430\u0435\u0442 \u043D\u0435\u0434\u0435\u043B\u044E.
        \u041D\u0430 \u043F\u043E\u0440\u043E\u0433\u0435 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0430
        \u0435\u0439 \u0441\u043A\u0430\u0437\u0430\u043B\u0438 \u043E\u0434\u043D\u043E
        \u0441\u043B\u043E\u0432\u043E: \u043C\u0435\u0441\u0442 \u043D\u0435\u0442.
        \u0414\u0432\u0435\u0440\u044C \u0437\u0430\u043A\u0440\u044B\u043B\u0438.
        \u0412\u0430\u043D\u0435\u0447\u043A\u0430 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B
        \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u044C \u0433\u043B\u0430\u0437\u0430.
        \u041C\u0430\u0442\u044C \u043D\u0435 \u0437\u043D\u0430\u0435\u0442, \u0447\u0442\u043E
        \u0441 \u0435\u0451 \u0434\u0435\u0442\u044C\u043C\u0438. \u041D\u0435 \u0437\u043D\u0430\u0435\u0442,
        \u043A\u0443\u0434\u0430 \u0438\u0434\u0442\u0438. \u041D\u0435 \u0437\u043D\u0430\u0435\u0442,
        \u0436\u0438\u0432 \u043B\u0438 \u0435\u0451 \u0441\u044B\u043D. \u041E\u043D\u0430
        \u043F\u0440\u043E\u0441\u0438\u0442 \u043D\u0435 \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432
        \u2014 \u043E\u043D\u0430 \u043F\u0440\u043E\u0441\u0438\u0442, \u0447\u0442\u043E\u0431\u044B
        \u043A\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C \u043F\u0440\u0438\u0448\u0451\u043B
        \u0438 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043A\u0430\u0437\u0430\u043B,
        \u0447\u0442\u043E \u0441 \u043D\u0438\u043C\u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442."
      factionAPoints: 0
      factionBPoints: 0
      requiredIntelKey: {fileID: 0}
      nextBlockIndex: 4
    isFinalBlock: 0
  - blockLabel: 
    phraseOptions:
    - text: "\u0418 \u0432\u0441\u0451 \u0436\u0435 \u0432\u0440\u0430\u0447\u0438
        \u043D\u0435 \u0443\u0445\u043E\u0434\u044F\u0442. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
        \u043D\u0430 \u0443\u0433\u0440\u043E\u0437\u044B, \u043D\u0435\u0445\u0432\u0430\u0442\u043A\u0443
        \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u043E\u0432
        \u0438 \u0431\u0438\u043D\u0442\u043E\u0432, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
        \u043D\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
        \u043E\u0447\u0435\u0440\u0435\u0434\u0438 \u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
        \u0441\u043C\u0435\u043D \u2014 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u044B
        \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0442 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C.
        \u0421\u0438\u0442\u0443\u0430\u0446\u0438\u044F \u0434\u0430\u043B\u0435\u043A\u0430
        \u043E\u0442 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0439, \u0438
        \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
        \u043F\u0440\u0438\u0437\u043D\u0430\u0451\u0442 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C
        \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044F \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0445
        \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0435\u0439. \u041D\u043E \u043F\u043E\u043A\u0430
        \u044D\u0442\u043E\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E,
        \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u0430\u044F \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0430
        \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u043D\u0430 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
        \u0440\u0435\u0441\u0443\u0440\u0441\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
        \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
        \u043F\u043E \u043A\u0430\u0440\u0442\u043E\u0447\u043A\u0430\u043C \u2014
        \u043D\u0430 \u043B\u044E\u0434\u044F\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
        \u043A\u0430\u0436\u0434\u043E\u0435 \u0443\u0442\u0440\u043E \u043D\u0430\u0434\u0435\u0432\u0430\u044E\u0442
        \u0445\u0430\u043B\u0430\u0442 \u0438 \u0432\u044B\u0445\u043E\u0434\u044F\u0442
        \u043A \u0442\u0435\u043C, \u043A\u0442\u043E \u0432 \u043D\u0438\u0445 \u043D\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044F.
        \u0414\u0430\u0436\u0435 \u043A \u0442\u0435\u043C, \u043A\u0442\u043E \u0438\u043C
        \u0443\u0433\u0440\u043E\u0436\u0430\u0435\u0442."
