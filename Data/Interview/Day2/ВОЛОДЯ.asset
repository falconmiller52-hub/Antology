  m_Name: "\u0412\u041E\u041B\u041E\u0414\u042F"
  m_EditorClassIdentifier: Assembly-CSharp::InterviewData
  npcName: "\u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440"
  npcIcon: {fileID: 8221397018206217885, guid: 84756c98c9de58f4bb48ee713011d08e, type: 3}
  npcDescription: "\u0421\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u0430\u0434\u0438\u043E\u0432\u0435\u0449\u0430\u043D\u0438\u044F"
  voiceBlip: {fileID: 8300000, guid: 3fafad4924ab14f4c85983ecade15442, type: 3}
  voicePitch: 1
  nodes:
  - npcLine: "\u0410 \u0432\u043E\u0442 \u0438 \u043D\u043E\u0432\u0438\u0447\u043E\u043A!
      \u0421\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0448\u044C\u0441\u044F \u0441
      \u043D\u043E\u0432\u043E\u0439 \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0443\u0440\u043E\u0439?"
    responses:
    - text: "\u0414\u0430, \u0432\u043F\u043E\u043B\u043D\u0435. \u042F \u043D\u0435\u043D\u0430\u0434\u043E\u043B\u0433\u043E,
        \u043D\u0443\u0436\u043D\u043E \u043A\u043E\u0435-\u0447\u0442\u043E \u0441\u043F\u0440\u043E\u0441\u0438\u0442\u044C"
      nextNodeIndex: 1
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u042F \u0432\u0440\u044F\u0434-\u043B\u0438 \u0441\u043E\u0439\u0434\u0443
      \u0437\u0430 \u043D\u0430\u0434\u0435\u0436\u043D\u044B\u0439 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A,
      \u043D\u043E \u043A\u0430\u043A \u0445\u043E\u0447\u0435\u0448\u044C"
    responses:
    - text: "\u042F \u0432\u0441\u0435 \u0435\u0436\u0435 \u0441\u043F\u0440\u043E\u0448\u0443"
      nextNodeIndex: 2
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: ...
    responses:
    - text: "\u0412 \u0433\u043E\u0440\u043E\u0434\u0435 \u043F\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
        \u043A\u0430\u043A\u0438\u0435-\u0442\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
        \u041E\u041F\u0413? \u0418\u043B\u0438 \u043E\u043F\u043F\u043E\u0437\u0438\u0446\u0438\u044F?\_"
      nextNodeIndex: 3
      endsInterview: 0
    - text: "\u0422\u0435\u0431\u0435 \u043D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
        \u0447\u0442\u043E \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0430
        \u0442\u043E\u043B\u044C\u043A\u043E \u0438 \u0434\u0435\u043B\u0430\u0435\u0442,
        \u0447\u0442\u043E \u043E\u043F\u0443\u0441\u043A\u0430\u0435\u0442\u0441\u044F?"
      nextNodeIndex: 6
      endsInterview: 0
    - text: "\u0427\u0442\u043E \u0434\u0443\u043C\u0430\u0435\u0448\u044C \u043E
        \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0439 \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u0438?"
      nextNodeIndex: 8
      endsInterview: 0
    - text: "\u0421\u043B\u044B\u0448\u0430\u043B \u043F\u0440\u043E \u0441\u043B\u0443\u0447\u0430\u0438
        \u0430\u0440\u0435\u0441\u0442\u043E\u0432 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u0432?"
      nextNodeIndex: 12
      endsInterview: 0
    - text: "[\u0417\u0410\u041A\u041E\u041D\u0427\u0418\u0422\u042C]"
      nextNodeIndex: 22222
      endsInterview: 1
    isCyclic: 1
    intelKey: {fileID: 0}
  - npcLine: "\u041D\u0430 \u044D\u0442\u043E\u0442 \u0441\u0447\u0435\u0442 \u043C\u043E\u0436\u0435\u0448\u044C
      \u043D\u0435 \u0432\u043E\u043B\u043D\u043E\u0432\u0430\u0442\u044C\u0441\u044F,
      \u043D\u0438\u043A\u0430\u043A\u043E\u0439 \u0432\u0441\u0435\u0441\u0438\u043B\u044C\u043D\u043E\u0439
      \u041E\u041F\u0413 \u0437\u0434\u0435\u0441\u044C \u0434\u043E \u0441\u0438\u0445
      \u043F\u043E\u0440 \u043D\u0435\u0442 \u0438 \u0432\u0440\u044F\u0434 \u043B\u0438
      \u043F\u043E\u044F\u0432\u0438\u0442\u0441\u044F \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0435
      \u0432\u0440\u0435\u043C\u044F. \u041A\u0430\u043A \u0438 \u043E\u043F\u043F\u043E\u0437\u0438\u0446\u0438\u044F.
      \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435"
    responses:
    - text: "\u041F\u043E\u0447\u0435\u043C\u0443 \u0442\u044B \u0442\u0430\u043A
        \u0432 \u044D\u0442\u043E\u043C \u0443\u0432\u0435\u0440\u0435\u043D?"
      nextNodeIndex: 4
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043D\u0435
      \u043F\u0435\u0440\u0432\u044B\u0439 \u0434\u0435\u043D\u044C \u0437\u043D\u0430\u044E
      \u043A\u0430\u043A \u0443\u0441\u0442\u0440\u043E\u0435\u043D\u0430 \u043D\u0430\u0448\u0430
      \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430
      \u0438 \u043F\u043E\u0434\u043F\u043E\u043B\u044C\u043D\u044B\u0439. \u0422\u0435\u0431\u0435
      \u0431\u044B \u043F\u043E\u0431\u043E\u043B\u0442\u0430\u0442\u044C \u0441
      \u0443\u043C\u043D\u044B\u043C\u0438 \u043B\u044E\u0434\u044C\u043C\u0438,
      \u043C\u043D\u043E\u0433\u043E\u0435 \u0443\u0437\u043D\u0430\u0435\u0448\u044C!"
    responses:
    - text: "\u042D\u0442\u043E \u044F \u0438 \u0434\u0435\u043B\u0430\u044E \u043D\u0430
        \u0440\u0430\u0431\u043E\u0442\u0435..."
      nextNodeIndex: 5
      endsInterview: 0
    isCyclic: 1
    intelKey: {fileID: 0}
  - npcLine: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E. \u0412\u043E\u043E\u0431\u0449\u0435\u043C,
      \u0434\u0438\u0432\u0435\u0440\u0441\u0438\u0438 \u0432\u0441\u0435 \u0435\u0449\u0435
      \u0435\u0441\u0442\u044C, \u043A\u0430\u043A \u0438 \u043D\u0435\u043B\u0435\u043F\u044B\u0435
      \u0442\u0435\u043E\u0440\u0438\u0438 \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0430.
      \u0412\u0435\u0440\u0438\u0442\u044C \u043B\u0438 \u0432 \u043D\u0438\u0445
      \u0438\u043B\u0438 \u043D\u0435\u0442 - \u0442\u0432\u043E\u0439 \u0432\u044B\u0431\u043E\u0440"
    responses:
    - text: ...
      nextNodeIndex: 2
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041F\u0440\u043E\u0433\u043D\u043E\u0437\u044B \u0438 \u043F\u0440\u0430\u0432\u0434\u0430
      \u0436\u0443\u0442\u043A\u0438\u0435... \u041D\u043E \u0441 \u0434\u0440\u0443\u0433\u043E\u0439
      \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u043C\u043E\u0436\u043D\u043E
      \u043B\u0438 \u0432\u0435\u0440\u0438\u0442\u044C \u043F\u0440\u043E\u0433\u043D\u043E\u0437\u0430\u043C?
      \u0414\u0430 \u0438 \u0447\u0442\u043E \u0441 \u043D\u0438\u043C\u0438 \u043C\u043E\u0436\u043D\u043E
      \u0441\u0434\u0435\u043B\u0430\u0442\u044C?"
    responses:
    - text: "\u042F \u0441\u043A\u043E\u0440\u0435\u0435 \u043A \u0442\u043E\u043C\u0443,
        \u0447\u0442\u043E \u043D\u0430\u0441 \u0432\u043F\u043E\u043B\u043D\u0435
        \u043C\u043E\u0436\u0435\u0442 \u0436\u0434\u0430\u0442\u044C \u0435\u0449\u0435
        \u0431\u043E\u043B\u0435\u0435 \u0436\u0435\u0441\u0442\u043A\u0438\u0435
        \u0445\u043E\u043B\u043E\u0434\u0430 \u0447\u0435\u043C \u0441\u0435\u0439\u0447\u0430\u0441..."
      nextNodeIndex: 7
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0418\u043D\u0436\u0435\u043D\u0435\u0440\u044B \u0438\u0442\u0430\u043A
      \u043B\u043E\u043C\u0430\u044E\u0442 \u0433\u043E\u043B\u043E\u0432\u044B \u043D\u0430\u0434
      \u0442\u0435\u043F\u043B\u043E\u0432\u044B\u043C\u0438 \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440\u0430\u043C\u0438
      \u0438 \u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C.
      \u0422\u0430\u043A \u0447\u0442\u043E... \u0445\u043E\u0442\u044C \u043A\u0430\u043A\u0430\u044F-\u0442\u043E
      \u043D\u0430\u0434\u0435\u0436\u0434\u0430 \u0443 \u043D\u0430\u0441 \u0432\u0441\u0435
      \u0435\u0449\u0435 \u0435\u0441\u0442\u044C"
    responses:
    - text: "\u041D\u0443, \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u043C \u044D\u0442\u043E
        \u0442\u043E\u0436\u0435 \u0432\u0430\u0436\u043D\u043E"
      nextNodeIndex: 2
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u042D\u0442\u043E \u043D\u0435 \u043F\u043E \u043C\u043E\u0435\u0439
      \u043A\u043E\u043C\u043F\u0435\u0442\u0435\u043D\u0446\u0438\u0438, \u043D\u043E
      \u0434\u0435\u043B\u0430 \u0438 \u043F\u0440\u0430\u0432\u0434\u0430 \u043D\u0435
      \u043B\u0443\u0447\u0448\u0438\u0435. \u0412\u043E\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
      \u0447\u0442\u043E \u0441 \u044D\u0442\u0438\u043C \u0441\u0434\u0435\u043B\u0430\u0435\u0448\u044C?
      \u0422\u044F\u0436\u043A\u0438\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430,
      \u043D\u0438 \u0431\u043E\u043B\u044C\u0448\u0435, \u043D\u0438 \u043C\u0435\u043D\u044C\u0448\u0435"
    responses:
    - text: "\u0414\u0430\u0436\u0435 \u043D\u0435 \u0437\u043D\u0430\u044E... \u041D\u0430\u0434\u043E
        \u0432\u0435\u0434\u044C \u043A\u0430\u043A-\u0442\u043E \u043E\u0441\u0432\u0435\u0442\u0438\u0442\u044C
        \u044D\u0442\u043E \u0447\u0442\u043E-\u043B\u0438..."
      nextNodeIndex: 9
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u0430\u044F \u043C\u044B\u0441\u043B\u044C.
      \u0410 \u0447\u0442\u043E \u0442\u044B \u044D\u0442\u0438\u043C \u0445\u043E\u0447\u0435\u0448\u044C
      \u0434\u043E\u0431\u0438\u0442\u044C\u0441\u044F?"
    responses:
    - text: "\u041D\u0435 \u043F\u043E\u043D\u044F\u043B \u0432\u043E\u043F\u0440\u043E\u0441\u0430.\_"
      nextNodeIndex: 10
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u042F \u0441\u043F\u0440\u043E\u0441\u0438\u043B, \"\u0447\u0435\u0433\u043E
      \u0442\u044B \u0445\u043E\u0447\u0435\u0448\u044C \u0434\u043E\u0431\u0438\u0442\u044C\u0441\u044F\"?
      \u041F\u043E\u0434\u043E\u0431\u043D\u044B\u0435 \u043D\u043E\u0432\u043E\u0441\u0442\u0438
      \u043C\u043E\u0433\u0443\u0442 \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438
      \u043A \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443
      \u0440\u0435\u0437\u043E\u043D\u0430\u043D\u0441\u0443. \u0422\u0430\u043A
      \u0432\u043E\u0442, \u0447\u0435\u0433\u043E \u0442\u044B \u0445\u043E\u0447\u0435\u0448\u044C
      \u0434\u043E\u0431\u0438\u0442\u044C\u0441\u044F?"
    responses:
    - text: "...\u042F \u043D\u0435 \u0438\u043C\u0435\u043B \u0432 \u0432\u0438\u0434\u0443
        \u043D\u0438\u0447\u0435\u0433\u043E \u0442\u0430\u043A\u043E\u0433\u043E"
      nextNodeIndex: 11
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0414\u0430 \u044F \u0448\u0443\u0447\u0443! \u041D\u043E \u0432\u0441\u0435
      \u0440\u0430\u0432\u043D\u043E, \u0431\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u0435\u0435
      \u0441\u043E \u0441\u0432\u043E\u0438\u043C\u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430\u043C\u0438.
      \u041D\u0430 \u0431\u0443\u0434\u0443\u0449\u0435\u0435."
    responses:
    - text: "\u041F\u043E\u043D\u044F\u043B"
      nextNodeIndex: 2
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0414\u0430 \u044F \u0448\u0443\u0447\u0443! \u041D\u043E \u0432\u0441\u0435
      \u0440\u0430\u0432\u043D\u043E, \u0431\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u0435\u0435
      \u0441\u043E \u0441\u0432\u043E\u0438\u043C\u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430\u043C\u0438.
      \u041D\u0430 \u0431\u0443\u0434\u0443\u0449\u0435\u0435."
    responses:
    - text: "\u0414\u0443\u043C\u0430\u0435\u0448\u044C?"
      nextNodeIndex: 13
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041D\u0443 \u043A\u043E\u043D\u0435\u0447\u043D\u043E! \u0415\u0433\u043E
      \u0432\u0435\u0434\u044C \u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u0434\u043A\u0443\u043F\u0438\u0442\u044C
      \u0438\u043B\u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u0442\u044C,
      \u0437\u0430\u0442\u0435\u043C \u0435\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E
      \u0441\u0434\u0430\u043B\u0438 \u0438\u043B\u0438 \u043F\u043E\u0434\u0441\u0442\u0430\u0432\u0438\u043B\u0438"
    responses:
    - text: "\u041D\u043E \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u0443\u043B\u0438\u043A
        \u043F\u043E \u044D\u0442\u043E\u0439 \u0447\u0430\u0441\u0442\u0438 \u043D\u0435\u0442,
        \u0442\u0430\u043A \u0447\u0442\u043E \u044D\u0442\u043E \u0432\u0441\u0435\u0433\u043E
        \u043B\u0438\u0448\u044C \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430"
      nextNodeIndex: 14
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 11400000, guid: a975e7dd17a10fc4f98f8a5a8301eb3e, type: 2}
  - npcLine: "\u041D\u0443 \u043A\u043E\u043D\u0435\u0447\u043D\u043E! \u0415\u0433\u043E
      \u0432\u0435\u0434\u044C \u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u0434\u043A\u0443\u043F\u0438\u0442\u044C
      \u0438\u043B\u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u0442\u044C,
      \u0437\u0430\u0442\u0435\u043C \u0435\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E
      \u0441\u0434\u0430\u043B\u0438 \u0438\u043B\u0438 \u043F\u043E\u0434\u0441\u0442\u0430\u0432\u0438\u043B\u0438"
