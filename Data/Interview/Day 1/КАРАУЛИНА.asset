  npcDescription: "\u0413\u043B\u0430\u0432\u0432\u0440\u0430\u0447 \u043F\u043E
    \u0446\u0435\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u043C \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0430\u043C"
  voiceBlip: {fileID: 8300000, guid: 3fafad4924ab14f4c85983ecade15442, type: 3}
  voicePitch: 1
  nodes:
  - npcLine: "\u041C\u0435\u043D\u044F \u0432\u0435\u0434\u044C \u0441\u043B\u044B\u0448\u043D\u043E?"
    responses:
    - text: "\u0414\u0430, \u043E\u0447\u0435\u043D\u044C \u0445\u043E\u0440\u043E\u0448\u043E!
        \u0414\u043E\u0431\u0440\u044B\u0439 \u0434\u0435\u043D\u044C!"
      nextNodeIndex: 1
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E, \u044F \u043D\u0430\u0434\u0435\u044E\u0441\u044C
      \u044D\u0442\u043E \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E \u0431\u0443\u0434\u0435\u0442
      \u043D\u0435\u0434\u043E\u043B\u0433\u0438\u043C, \u043C\u043D\u043E\u0433\u043E
      \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u0438\u0439 \u043D\u0430 \u044D\u0442\u043E\u0439
      \u043D\u0435\u0434\u0435\u043B\u0435, \u0441\u0430\u043C\u0438 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442\u0435..."
    responses:
    - text: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E! \u0414\u0443\u043C\u0430\u044E,
        \u043C\u044B \u0431\u044B\u0441\u0442\u0440\u043E \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043C"
      nextNodeIndex: 2
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: ...
    responses:
    - text: "\u041A\u0430\u043A \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435
        \u043F\u0440\u043E\u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
        \u043D\u044B\u043D\u0435\u0448\u043D\u044E\u044E \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E
        \u0441 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C
        \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u043E\u0439 \u043F\u043E\u043C\u043E\u0449\u0438
        \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044E?"
      nextNodeIndex: 3
      endsInterview: 0
    - text: "\u0421 \u0447\u0435\u043C \u0441\u0432\u044F\u0437\u0430\u043D \u0434\u0435\u0444\u0438\u0446\u0438\u0442
        \u043C\u0435\u0441\u0442 \u0432 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u0430\u0445?"
      nextNodeIndex: 6
      endsInterview: 0
    - text: "\u041C\u043E\u0436\u043D\u043E \u043B\u0438 \u043F\u0440\u043E\u0433\u043D\u043E\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
        \u0441\u043A\u043E\u0440\u0443\u044E \u0432\u0441\u043F\u044B\u0448\u043A\u0443
        \u0433\u0440\u0438\u043F\u043F\u0430? \u041A \u0447\u0435\u043C\u0443 \u0431\u044B\u0442\u044C
        \u0433\u043E\u0442\u043E\u0432\u044B\u043C?"
      nextNodeIndex: 7
      endsInterview: 0
    - text: "[\u0417\u0410\u041A\u041E\u041D\u0427\u0418\u0422\u042C]"
      nextNodeIndex: 2222
      endsInterview: 1
    isCyclic: 1
    intelKey: {fileID: 0}
  - npcLine: "\u041D\u0430 \u0434\u0430\u043D\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442
      \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
      \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043E\u0447\u0435\u043D\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0435.
      \u0412\u0435\u0441\u044C \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
      \u043D\u0430 \u0441\u0432\u0435\u0440\u0445\u0443\u0440\u043E\u0447\u043D\u044B\u0445,
      \u0432\u0441\u0435 \u0436\u0435\u0440\u0442\u0432\u0443\u044E\u0442 \u0441\u043D\u043E\u043C,
      \u043D\u043E \u0438\u043D\u0430\u0447\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
      \u043D\u0435\u043B\u044C\u0437\u044F \u0432 \u0442\u0430\u043A\u043E\u0435
      \u0432\u0440\u0435\u043C\u044F"
    responses:
    - text: "\u0414\u0430, \u044D\u0442\u043E \u0438 \u043F\u0440\u0430\u0432\u0434\u0430
        \u0442\u0430\u043A, \u0438 \u043C\u043D\u043E\u0433\u0438\u0435 \u0436\u0430\u043B\u0443\u044E\u0442\u0441\u044F
        \u043D\u0430 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u043E\u0432..."
      nextNodeIndex: 4
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041F\u043E\u0432\u0435\u0440\u044C\u0442\u0435, \u043C\u044B \u0432\u0441\u0435\u0445
      \u0438\u0445 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u043C.
      \u041D\u043E \u0445\u043E\u0447\u0435\u0442\u0441\u044F \u0441\u043A\u0430\u0437\u0430\u0442\u044C
      \u0437\u0430 \u0432\u0441\u0435\u0445 \u043C\u043E\u0438\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432,
      \u0447\u0442\u043E \u043C\u044B \u0442\u043E\u0436\u0435 \u0445\u043E\u0442\u0438\u043C
      \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F. \u0412 \u043A\u043E\u043D\u0446\u0435
      \u043A\u043E\u043D\u0446\u043E\u0432 \u043C\u044B \u0432\u0441\u0435 \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
      \u0432 \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438.
      \u0421\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0441\u0442\u0440\u0430\u0448\u043D\u043E
      \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0437\u0430 \u0441\u0432\u043E\u044E
      \u0436\u0438\u0437\u043D\u044C, \u043D\u043E \u0438 \u0437\u0430 \u0436\u0438\u0437\u043D\u044C
      \u0431\u043B\u0438\u0437\u043A\u0438\u0445"
    responses:
    - text: "\u041E\u0447\u0435\u043D\u044C \u043D\u0430\u0434\u0435\u044E\u0441\u044C,
        \u0447\u0442\u043E \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
        \u0443\u043B\u0443\u0447\u0448\u0438\u0442\u0441\u044F \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0435
        \u0432\u0440\u0435\u043C\u044F..."
      nextNodeIndex: 2
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041F\u043E\u0432\u0435\u0440\u044C\u0442\u0435, \u043C\u044B \u0432\u0441\u0435\u0445
      \u0438\u0445 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u043C.
      \u041D\u043E \u0445\u043E\u0447\u0435\u0442\u0441\u044F \u0441\u043A\u0430\u0437\u0430\u0442\u044C
      \u0437\u0430 \u0432\u0441\u0435\u0445 \u043C\u043E\u0438\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432,
      \u0447\u0442\u043E \u043C\u044B \u0442\u043E\u0436\u0435 \u0445\u043E\u0442\u0438\u043C
      \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F. \u0412 \u043A\u043E\u043D\u0446\u0435
      \u043A\u043E\u043D\u0446\u043E\u0432 \u043C\u044B \u0432\u0441\u0435 \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
      \u0432 \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438.
      \u0421\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0441\u0442\u0440\u0430\u0448\u043D\u043E
      \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0437\u0430 \u0441\u0432\u043E\u044E
      \u0436\u0438\u0437\u043D\u044C, \u043D\u043E \u0438 \u0437\u0430 \u0436\u0438\u0437\u043D\u044C
      \u0431\u043B\u0438\u0437\u043A\u0438\u0445"
    responses:
    - text: "\u041D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
        \u0441\u043E \u043C\u043D\u043E\u0433\u0438\u043C\u0438 \u0444\u0430\u043A\u0442\u043E\u0440\u0430\u043C\u0438.
        \u041D\u043E \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u0438\u0437-\u0437\u0430
        \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
        \u043F\u0440\u0438\u0431\u044B\u0432\u0430\u044E\u0449\u0438\u0445 \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u043E\u0432.
        \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043C\u044B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u044B
        \u043E\u0431\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u0442\u044C \u043D\u0430
        \u0441\u044B\u0440\u043E\u0439 \u0437\u0435\u043C\u043B\u0435..."
      nextNodeIndex: 5
      endsInterview: 0
    isCyclic: 1
    intelKey: {fileID: 0}
  - npcLine: "\u041A\u0430\u043A\u043E\u0439 \u0443\u0436\u0430\u0441... \u041D\u0435\u0443\u0436\u0435\u043B\u0438
      \u043D\u0435 \u043F\u043B\u0430\u043D\u0438\u0440\u0443\u0435\u0442\u0441\u044F
      \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
      \u043B\u0430\u0437\u0430\u0440\u0435\u0442\u043E\u0432 \u0432 \u0442\u0430\u043A\u043E\u043C
      \u0441\u043B\u0443\u0447\u0430\u0435?"
    responses:
    - text: "\u042F \u043D\u0435 \u043C\u043E\u0433\u0443 \u0442\u043E\u0447\u043D\u043E
        \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0442\u044C, \u043D\u043E
        \u044F \u0441\u043B\u044B\u0448\u0430\u043B\u0430 \u043E\u0431 \u043E\u0431\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0438
        \u0442\u0430\u043A\u043E\u0433\u043E \u043F\u0440\u043E\u0435\u043A\u0442\u0430.
        \u041D\u043E \u0432\u043E\u0442 \u043F\u043E\u043B\u0443\u0447\u0438\u0442
        \u043B\u0438 \u043E\u043D \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
        - \u0432\u0441\u0435 \u0435\u0449\u0435 \u043D\u0435\u043F\u043E\u043D\u044F\u0442\u043D\u043E.\_"
