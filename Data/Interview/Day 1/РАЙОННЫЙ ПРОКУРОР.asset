    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0428\u0443\u0447\u0443, \u043A\u043E\u043D\u0435\u0447\u043D\u043E
      \u0436\u0435 \u043C\u044B \u0434\u0435\u043B\u0430\u0435\u043C \u0432\u0441\u0435,
