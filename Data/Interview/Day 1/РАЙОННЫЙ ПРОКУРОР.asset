      \u043B\u044E\u0431\u044B\u0435 \u0431\u0435\u0441\u043F\u043E\u0440\u044F\u0434\u043A\u0438,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0433\u0443\u0442 \u0432\u043E\u0437\u043D\u0438\u043A\u043D\u0443\u0442\u044C.
      \u041C\u044B \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u043C
      \u0432\u0435\u0440\u043D\u044B\u0435 \u0448\u0430\u0433\u0438 \u043D\u0430\u0432\u0441\u0442\u0440\u0435\u0447\u0443
      \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
      \u043F\u043E\u0440\u044F\u0434\u043A\u0430, \u0445\u043E\u0442\u044C \u044D\u0442\u043E
