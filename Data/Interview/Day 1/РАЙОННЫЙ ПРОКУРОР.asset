      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E..."
    responses:
    - text: "\u041C\u043E\u0436\u0435\u0442\u0435, \u043F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
        \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C\u0441\u044F?"
      nextNodeIndex: 2
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0410 \u0442\u044B \u0447\u0442\u043E, \u043D\u0435 \u0437\u043D\u0430\u0435\u0448\u044C
      \u043A\u043E\u043C\u0443 \u0437\u0432\u043E\u043D\u0438\u0448\u044C?"
    responses:
    - text: "\u0414\u0430,, \u044F \u0437\u043D\u0430\u044E, \u0447\u0442\u043E \u0432\u044B
        \u0440\u0430\u0439\u043E\u043D\u043D\u044B\u0439 \u043F\u0440\u043E\u043A\u0443\u0440\u043E\u0440,
        \u043F\u0440\u043E\u0441\u0442\u043E \u0432 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0439
        \u0431\u0430\u0437\u0435 \u0434\u0430\u043D\u043D\u044B\u0445 \u043F\u043E\u0447\u0435\u043C\u0443-\u0442\u043E
        \u0443 \u0432\u0430\u0441 \u043D\u0435\u0442\u0443 \u0438\u043C\u0435\u043D\u0438..."
      nextNodeIndex: 3
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0414\u0430\u043D\u043D\u044B\u0435 \u0431\u044B\u043B\u0438 \u043D\u0435\u0432\u0435\u0440\u043D\u044B\u0435,
      \u0442\u0430\u043A\u043E\u0435 \u0431\u044B\u0432\u0430\u0435\u0442"
    responses:
    - text: "\u041D\u0435\u0432\u0435\u0440\u043D\u044B\u0435 \u0434\u0430\u043D\u043D\u044B\u0435
        \u0432 \u0438\u043D\u0438\u0446\u0438\u0430\u043B\u0430\u0445?\_"
      nextNodeIndex: 4
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0414\u0430. \u0421\u0430\u043C \u0437\u043D\u0430\u0435\u0448\u044C,
      \u0431\u044E\u0440\u043E\u043A\u0440\u0430\u0442\u0438\u044F, \u043E\u043D\u0430
      \u0438 \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u043E\u043D\u0446\u0430
      \u0441\u0432\u0435\u0442\u0430 \u0431\u044E\u0440\u043E\u043A\u0440\u0430\u0442\u0438\u044F"
    responses:
    - text: "\u042D\u0442\u043E \u0432\u044B \u0432\u0435\u0440\u043D\u043E \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0438...
        \u0422\u043E\u0433\u0434\u0430, \u043C\u043E\u0436\u0435\u0442\u0435 \u0432\u0441\u0435
        \u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C\u0441\u044F?"
      nextNodeIndex: 5
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0410 \u0442\u0435\u0431\u0435 \u0440\u0430\u0437\u0432\u0435 \u043D\u0443\u0436\u043D\u043E
      \u043C\u043E\u0435 \u0438\u043C\u044F?"
    responses:
    - text: "\u0414\u0430... \u0414\u043B\u044F \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D\u0438\u044F
        \u0446\u0438\u0442\u0430\u0442. \u0412\u0441\u0435 \u043B\u0438\u0448\u044C
        \u0440\u0430\u0434\u0438 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F
        \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0441\u0442\u0438
        \u0441\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u0433\u043E \u0432 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0435"
      nextNodeIndex: 6
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0412\u043E\u0442 \u043A\u0430\u043A \u0432\u0441\u0435 \u043B\u0435\u0433\u043A\u043E,
      \u0435\u0441\u043B\u0438 \u044F \u043D\u0435 \u0441\u043A\u0430\u0436\u0443
      \u0442\u0435\u0431\u0435 \u0438\u043C\u044F, \u0432\u0441\u0435 \u0441\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u0435
      \u043C\u043D\u043E\u0439 \u043D\u0435 \u0431\u0443\u0434\u0435\u0442 \u0438\u043C\u0435\u0442\u044C
      \u0434\u043B\u044F \u0442\u0435\u0431\u044F \u0441\u043C\u044B\u0441\u043B\u0430,
      \u0438 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u0441\u0442\u0430\u0442\u044C\u044E
      \u043D\u0435\u043B\u044C\u0437\u044F \u0431\u0443\u0434\u0435\u0442. \u041D\u0435\u0437\u0430\u0432\u0438\u0434\u043D\u043E\u0435
      \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435, \u0434\u0430?"
    responses:
    - text: "\u041D\u0435 \u0441\u043E\u0432\u0441\u0435\u043C \u043F\u043E\u043D\u0438\u043C\u0430\u044E
        \u043A \u0447\u0435\u043C\u0443 \u0432\u044B..."
      nextNodeIndex: 7
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0421\u043A\u0430\u0436\u0435\u043C \u0442\u0430\u043A, \u043C\u043D\u0435
      \u043E\u0447\u0435\u043D\u044C \u0432\u0430\u0436\u043D\u043E, \u0447\u0442\u043E\u0431\u044B
      \u0432\u044B \u0432\u0435\u0440\u043D\u043E \u043D\u0430\u043F\u0438\u0441\u0430\u043B\u0438
      \u043D\u043E\u0432\u043E\u0441\u0442\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B.
      \u042D\u0442\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F
      \u043C\u043E\u0436\u0435\u0442 \u043D\u0430 \u043E\u0447\u0435\u043D\u044C
      \u043C\u043D\u043E\u0433\u043E\u0435 \u043F\u043E\u0432\u043B\u0438\u044F\u0442\u044C
      \u0432 \u043D\u0430\u0448\u0435\u0439 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438,
      \u0435\u0441\u043B\u0438 \u0442\u044B \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C.
      \u043E \u0447\u0435\u043C \u044F"
    responses:
    - text: "\u0414\u0430... \u0414\u043E\u043F\u0443\u0441\u0442\u0438\u043C"
      nextNodeIndex: 8
      endsInterview: 0
    isCyclic: 0
    intelKey: {fileID: 0}
  - npcLine: ...
    responses:
    - text: "\u041A\u0430\u043A \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435
        \u043E\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u043E\u0432\u0430\u0442\u044C
        \u043D\u044B\u043D\u0435\u0448\u043D\u044E\u044E \u043E\u0431\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443
