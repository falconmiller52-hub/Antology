    - text: ...
      nextNodeIndex: 7
      endsInterview: 0
    intelKey: {fileID: 0}
  - npcLine: "\u042F \u0436\u0434\u0443 \u0432\u0430\u0448\u0438\u0445 \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432"
    type: 1
    nextNodeIndex: 8
    responses:
    - text: "\u0410, \u0434\u0430? \u041F\u0440\u043E\u0441\u0442\u0438\u0442\u0435,
        \u044F \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u0442\u043E\u0440\u043E\u0439
        \u0434\u0435\u043D\u044C \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0435"
      nextNodeIndex: 8
      endsInterview: 0
    intelKey: {fileID: 0}
  - npcLine: ...
    type: 1
    nextNodeIndex: 9
    responses:
    - text: "\u041E\u0437\u0435\u0440\u043D\u044B\u0439 \u044D\u0442\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
        \u0433\u043E\u0440\u043E\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
        \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0430\u0435\u0442
        \u0441 \u043D\u0430\u043C\u0438? \u0415\u0441\u0442\u044C \u043A\u0442\u043E-\u0442\u043E
        \u0435\u0449\u0435?"
      nextNodeIndex: 9
      endsInterview: 0
    - text: "\u0412 \u043A\u0430\u043A\u043E\u0439 \u043E\u0431\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0435
        \u0441\u0435\u0439\u0447\u0430\u0441 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
        \u041E\u0437\u0435\u0440\u043D\u044B\u0439? \u0420\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442\u0435
        \u043B\u0438 \u0432\u044B \u0435\u0433\u043E \u043A\u0430\u043A \u043C\u043E\u0449\u043D\u043E\u0433\u043E
        \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
        \u0441\u043E\u044E\u0437\u043D\u0438\u043A\u0430?\_"
      nextNodeIndex: 13
      endsInterview: 0
    - text: "[\u0417\u0410\u041A\u041E\u041D\u0427\u0418\u0422\u042C]"
      nextNodeIndex: -1
      endsInterview: 1
    intelKey: {fileID: 0}
  - npcLine: "\u0421\u0442\u043E\u0438\u0442 \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C,
      \u0447\u0442\u043E \u041E\u0437\u0435\u0440\u043D\u044B\u0439 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D
      \u0431\u043B\u0438\u0436\u0435 \u0432\u0441\u0435\u0433\u043E \u043A \u041B\u0435\u0434\u043E\u0433\u0440\u0430\u0434\u0443,
      \u0431\u044B\u0441\u0442\u0440\u044B\u0435 \u043F\u043E\u0441\u0442\u0430\u0432\u043A\u0438
      \u0438 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0439 \u0440\u0438\u0441\u043A
      \u0432\u043C\u0435\u0448\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
      \u043F\u043E\u0433\u043E\u0434\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u0439..."
    type: 1
    nextNodeIndex: 10
    responses:
    - text: "\u0412\u043E\u043F\u0440\u043E\u0441 \u0431\u044B\u043B \u0432 \u0434\u0440\u0443\u0433\u043E\u043C..."
      nextNodeIndex: 10
      endsInterview: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041D\u043E \u0440\u0430\u0437\u0443\u043C\u0435\u0435\u0442\u0441\u044F
      \u043C\u044B \u0441\u0442\u0430\u0440\u0430\u0435\u043C\u0441\u044F \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
      \u0441\u0432\u044F\u0437\u044C \u0441 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438
      \u0448\u0442\u0430\u0431\u0430\u043C\u0438, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
      \u0441 \u0418\u0436\u0435\u0432\u0441\u043A\u043E\u043C, \u041B\u0435\u0431\u0435\u0434\u0435\u0432\u0441\u043A\u043E\u043C,
      \u041A\u0430\u043C\u0435\u043D\u0441\u043A\u0438\u043C \u0438 \u0425\u041D\u0420.
      \u042D\u0442\u043E\u043C\u0443 \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0443\u044E\u0442
      \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430"
    type: 1
    nextNodeIndex: 11
    responses:
    - text: "\u041C\u043E\u0436\u0435\u0442\u0435 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C,
        \u043A\u0430\u043A\u0438\u0435?"
