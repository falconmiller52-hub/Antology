  - npcLine: " \u042D\u0442\u043E \u043D\u0435 \u0442\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F,
      \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u0430\u0441 \u0434\u043E\u043B\u0436\u043D\u0430
      \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u0442\u044C, \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E
      \u044F \u043E\u0441\u0432\u0435\u0434\u043E\u043C\u043B\u0435\u043D."
    type: 1
