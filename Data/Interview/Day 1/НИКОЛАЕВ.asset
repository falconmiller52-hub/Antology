    intelKey: {fileID: 0}
  - npcLine: "\u041C\u044B \u043D\u0435 \u0440\u0430\u0441\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u043C
      \u0442\u043E\u0447\u043D\u043E\u0439 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0435\u0439,
      \u043D\u043E \u043C\u043E\u0436\u0435\u043C \u0437\u0430\u043C\u0435\u0442\u0438\u0442\u044C,
      \u0447\u0442\u043E \u0448\u0442\u0430\u0431 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
      \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u043D\u0430\u0434 \u0440\u044F\u0434\u043E\u043C
      \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
      \u0440\u0435\u0444\u043E\u0440\u043C \u043F\u043E \u0440\u0435\u0433\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
      \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0433\u043E \u0440\u044B\u043D\u043A\u0430"
    type: 1
    nextNodeIndex: 14
    responses:
    - text: "\u041F\u043E\u044D\u0442\u043E\u043C\u0443 \u043C\u044B \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u043C
