  npcDescription: "\u0413\u043B\u0430\u0432\u0430 \u0434\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u0438
    \u0432 \u041E\u0437\u0435\u0440\u043D\u044B\u0439"
  voiceBlip: {fileID: 8300000, guid: 154ec9e64db7c5843b72924366841cfb, type: 3}
  voicePitch: 1
  nodes:
  - npcLine: "\u0422\u0430\u043A, \u043A\u0430\u043A \u0441\u043B\u044B\u0448\u043D\u043E?"
    type: 1
    nextNodeIndex: 1
    responses:
    - text: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E, \u0441\u0432\u044F\u0437\u044C
        \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u0430\u044F"
      nextNodeIndex: 1
      endsInterview: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0425\u043E\u0440\u043E\u0448\u043E. \u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435,
      \u0432\u0441\u0435 \u043A\u0430\u043A \u0432\u0441\u0435\u0433\u0434\u0430.
      \u041F\u043E\u0431\u043E\u043B\u044C\u0448\u0435 \u0446\u0438\u0442\u0430\u0442,
      \u0435\u0441\u043B\u0438 \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u0438\u0442\u0441\u044F
      \u0431\u043E\u043B\u044C\u0448\u0435 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0430
      - \u0441\u043E\u043E\u0431\u0449\u0438\u0442\u0435"
    type: 1
    nextNodeIndex: 2
    responses:
    - text: "\u041F\u043E\u043D\u044F\u043B..."
      nextNodeIndex: 2
      endsInterview: 0
    intelKey: {fileID: 0}
  - npcLine: "\u041C\u044B \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u043C
      \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u044B\u0435
      \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u041E\u0437\u0435\u0440\u043D\u044B\u043C,
      \u043E\u0431 \u044D\u0442\u043E\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
      \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u043D\u0430\u0448\u0438\u0445 \u0434\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u0439..."
    type: 1
    nextNodeIndex: 3
    responses:
    - text: "\u042D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u043B\u0438\u0447\u043D\u043E!"
      nextNodeIndex: 3
      endsInterview: 0
    intelKey: {fileID: 11400000, guid: d679d1c106baabd4f8fa9c2fc0d656f6, type: 2}
  - npcLine: "\u041D\u0435 \u0441\u0431\u0438\u0432\u0430\u0439\u0442\u0435 \u0441
      \u043C\u044B\u0441\u043B\u0438, \u043F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
      \u0432\u0430\u043C \u043D\u0443\u0436\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u043E
      \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u043C\u043E\u0438 \u0441\u043B\u043E\u0432\u0430
      \u0432 \u044D\u0444\u0438\u0440. \u0412\u044B\u043F\u043E\u043B\u043D\u044F\u0439\u0442\u0435
      \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443 "
    type: 1
    nextNodeIndex: 4
    responses:
    - text: "\u041F\u0440\u043E\u0441\u0442\u0438\u0442\u0435..."
      nextNodeIndex: 4
      endsInterview: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0422\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D
      \u0434\u043E\u0433\u043E\u0432\u043E\u0440 \u043F\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0435
      \u043E\u0431\u043C\u0435\u043D\u0430 \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
      \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u043E\u0432 \u0438
      \u043F\u043E\u0441\u0442\u0430\u0432\u043A\u0430\u0445 \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u043E\u0432"
    type: 1
    nextNodeIndex: 5
    responses:
    - text: ...
      nextNodeIndex: 5
      endsInterview: 0
    intelKey: {fileID: 0}
  - npcLine: "\u0423\u0441\u043F\u0435\u0445 \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u043E\u0432
      \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0433\u043E\u0440\u043E\u0434
      \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043D\u0430 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0435 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E"
    type: 1
    nextNodeIndex: 6
